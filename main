local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Xeno Hub | Brookhaven 🏆",
   LoadingTitle = "Xeno Team Premier",
   LoadingSubtitle = "by Xeno Team",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "XenoConfigs",
      FileName = "XenoHub"
   },
   KeySystem = false 
})

-- Değişkenler
local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local RootPart = Character:WaitForChild("HumanoidRootPart")
local RS = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

-- Yardımcı Fonksiyonlar
local function GetPlayer(name)
    for _, v in pairs(game.Players:GetPlayers()) do
        if v.Name:lower():find(name:lower()) or v.DisplayName:lower():find(name:lower()) then
            return v
        end
    end
end

-- TABS
local MainTab = Window:CreateTab("Oyuncu Troll", 4483362458)
local WorldTab = Window:CreateTab("Dünya & Ev", 4483362458)
local VisualsTab = Window:CreateTab("Görsel & Avatar", 4483362458)
local MiscTab = Window:CreateTab("Diğer", 4483362458)

-- MAIN FEATURES (PLAYER TROLL)
MainTab:CreateSection("Hedef Belirle")

local targetPlayer = ""
MainTab:CreateInput({
   Name = "Oyuncu Adı",
   PlaceholderText = "İsim yazın...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      targetPlayer = Text
   end,
})

MainTab:CreateSection("İmha Yöntemleri")

MainTab:CreateButton({
   Name = "Kanepe İle Öldür (Couch Kill)",
   Callback = function()
      local target = GetPlayer(targetPlayer)
      if target then
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer("Couch", target.Character.HumanoidRootPart.CFrame)
         task.wait(0.2)
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer("Couch", CFrame.new(0, -500, 0))
      end
   end,
})

MainTab:CreateButton({
   Name = "Otobüs İle Uçur (Bus Kill)",
   Callback = function()
      local target = GetPlayer(targetPlayer)
      if target then
         RS:WaitForChild("RE"):WaitForChild("s1chool1bus"):FireServer(target.Name)
         task.wait(0.5)
         RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer("SetVehicleCFrame", CFrame.new(9999, 9999, 9999))
      end
   end,
})

MainTab:CreateButton({
   Name = "Evden Banlayarak Öldür (House Ban Kill)",
   Callback = function()
      local target = GetPlayer(targetPlayer)
      if target then
         RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("BanUser", target)
      end
   end,
})

MainTab:CreateSection("Genel Troll")

MainTab:CreateButton({
   Name = "Askeri Bot Fling (Military Boat)",
   Callback = function()
      RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer("SpawnVehicle", "MilitaryBoat", RootPart.CFrame)
      task.wait(0.5)
      local boat = workspace.Vehicles:FindFirstChild(Player.Name .. "MilitaryBoat")
      if boat then
          local bV = Instance.new("BodyAngularVelocity", boat.PrimaryPart)
          bV.AngularVelocity = Vector3.new(0, 99999, 0)
          bV.MaxTorque = Vector3.new(0, 99999, 0)
      end
   end,
})

MainTab:CreateToggle({
   Name = "Otomatik Bomba Patlat (Loop Bomb)",
   CurrentValue = false,
   Callback = function(Value)
      _G.LoopBomb = Value
      task.spawn(function()
         while _G.LoopBomb do
            local bombTool = workspace:WaitForChild("WorkspaceCom"):WaitForChild("001_CriminalWeapons"):WaitForChild("GiveTools"):WaitForChild("Bomb")
            if bombTool then
                fireclickdetector(bombTool.ClickDetector)
                task.wait(0.1)
                VIM:SendMouseButtonEvent(500, 500, 0, true, game, 0)
                task.wait(0.1)
                VIM:SendMouseButtonEvent(500, 500, 0, false, game, 0)
                RS:WaitForChild("RE"):WaitForChild("1Blo1wBomb1sServe1r"):FireServer("Bomb" .. Player.Name)
            end
            task.wait(1.5)
         end
      end)
   end,
})

