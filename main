scriptsTab:AddSection("🎥 Freecam Tool")

scriptsTab:AddButton({
    Name = "🎮 Full FreeCam (Final Version)",
    Callback = function()

        local Players = game:GetService("Players")
        local UserInputService = game:GetService("UserInputService")
        local RunService = game:GetService("RunService")

        local player = Players.LocalPlayer
        local character = player.Character or player.CharacterAdded:Wait()
        local humanoid = character:WaitForChild("Humanoid")
        local root = character:WaitForChild("HumanoidRootPart")
        local cam = workspace.CurrentCamera

        -- Tool
        local tool = Instance.new("Tool")
        tool.Name = "FreeCamByXenoHub"
		tool.TextureId = "rbxassetid://106398840014061"
        tool.RequiresHandle = false
        tool.Parent = player.Backpack

        -- UI
        local gui = Instance.new("ScreenGui")
        gui.Name = "FreeCamUI"
        gui.ResetOnSpawn = false
        gui.Enabled = false
        gui.Parent = player:WaitForChild("PlayerGui")

        -- Speed label
        local speedLabel = Instance.new("TextLabel", gui)
        speedLabel.Size = UDim2.new(0, 200, 0, 40)
        speedLabel.Position = UDim2.new(0.5, -100, 0, 10)
        speedLabel.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        speedLabel.BackgroundTransparency = 0.3
        speedLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        speedLabel.TextScaled = true
        speedLabel.Font = Enum.Font.GothamBold
        speedLabel.Text = "Speed: 1"

        local function createBtn(txt, pos)
            local b = Instance.new("TextButton", gui)
            b.Size = UDim2.new(0, 60, 0, 60)
            b.Position = pos
            b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
            b.TextColor3 = Color3.fromRGB(255, 255, 255)
            b.TextScaled = true
            b.Font = Enum.Font.GothamBold
            b.Text = txt
            b.AutoButtonColor = true
            return b
        end

        -- Mobile WASD
        local btnW = createBtn("W", UDim2.new(0.1, 0, 0.65, -60))
        local btnA = createBtn("A", UDim2.new(0.05, 0, 0.65, 0))
        local btnS = createBtn("S", UDim2.new(0.1, 0, 0.65, 60))
        local btnD = createBtn("D", UDim2.new(0.15, 0, 0.65, 0))

        -- Speed + / -
        local btnPlus = createBtn("+", UDim2.new(0.85, 0, 0.1, 0))
        local btnMinus = createBtn("-", UDim2.new(0.75, 0, 0.1, 0))

        local mobileInput = {W=false, A=false, S=false, D=false}

        btnW.MouseButton1Down:Connect(function() mobileInput.W = true end)
        btnW.MouseButton1Up:Connect(function() mobileInput.W = false end)

        btnA.MouseButton1Down:Connect(function() mobileInput.A = true end)
        btnA.MouseButton1Up:Connect(function() mobileInput.A = false end)

        btnS.MouseButton1Down:Connect(function() mobileInput.S = true end)
        btnS.MouseButton1Up:Connect(function() mobileInput.S = false end)

        btnD.MouseButton1Down:Connect(function() mobileInput.D = true end)
        btnD.MouseButton1Up:Connect(function() mobileInput.D = false end)

        -- Freecam vars
        local freecam = false
        local speed = 1
        local rotation = Vector2.new(0, 0)
        local rotSpeed = 1 -- hızlı dönüş
        local conn

        -- Speed buttons (mobile)
        btnPlus.MouseButton1Click:Connect(function()
            speed = math.clamp(speed + 0.5, 0.5, 10)
            speedLabel.Text = "Speed: " .. speed
        end)

        btnMinus.MouseButton1Click:Connect(function()
            speed = math.clamp(speed - 0.5, 0.5, 10)
            speedLabel.Text = "Speed: " .. speed
        end)

        -- Scroll speed (PC)
        UserInputService.InputChanged:Connect(function(input)
            if freecam and input.UserInputType == Enum.UserInputType.MouseWheel then
                speed = math.clamp(speed + input.Position.Z * 0.5, 0.5, 10)
                speedLabel.Text = "Speed: " .. speed
            end
        end)

        -- Speed presets 1 / 2 / 3
        UserInputService.InputBegan:Connect(function(input, gp)
            if not freecam or gp then return end

            if input.KeyCode == Enum.KeyCode.One then
                speed = 1
            elseif input.KeyCode == Enum.KeyCode.Two then
                speed = 3
            elseif input.KeyCode == Enum.KeyCode.Three then
                speed = 6
            end

            speedLabel.Text = "Speed: " .. speed
        end)

        -- FIX: Bacakların yere batmasını engelle
        local function fixLegs()
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = true
                end
            end
        end

        local function getMoveDir()
            local dir = Vector3.zero

            -- Keyboard + mobile
            if UserInputService:IsKeyDown(Enum.KeyCode.W) or mobileInput.W then dir += Vector3.new(0, 0, -1) end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) or mobileInput.S then dir += Vector3.new(0, 0, 1) end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) or mobileInput.A then dir += Vector3.new(-1, 0, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) or mobileInput.D then dir += Vector3.new(1, 0, 0) end

            -- Gamepad left stick
            local states = UserInputService:GetGamepadState(Enum.UserInputType.Gamepad1)
            if states[1] then
                local stick = states[1].Position
                dir += Vector3.new(stick.X, 0, -stick.Y)
            end

            return dir
        end

        local function getGamepadRotation()
            local states = UserInputService:GetGamepadState(Enum.UserInputType.Gamepad1)
            if states[2] then
                local stick = states[2].Position
                return Vector2.new(-stick.Y, -stick.X)
            end
            return Vector2.zero
        end

        local function enableFreecam()
            if freecam then return end
            freecam = true
            gui.Enabled = true

            -- FIX: Karakter düşmesin + ayaklar kaybolmasın
            fixLegs()
            root.Anchored = true
            humanoid.PlatformStand = false

            cam.CameraType = Enum.CameraType.Scriptable
            UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter

            conn = RunService.RenderStepped:Connect(function(dt)
                local delta = UserInputService:GetMouseDelta()
                local gpRot = getGamepadRotation()

                rotation = rotation + (Vector2.new(-delta.Y, -delta.X) + gpRot) * rotSpeed * dt

                local cf =
                    CFrame.new(cam.CFrame.Position)
                    * CFrame.Angles(0, rotation.Y, 0)
                    * CFrame.Angles(rotation.X, 0, 0)

                cam.CFrame = cf + cf:VectorToWorldSpace(getMoveDir() * speed)
            end)
        end

        local function disableFreecam()
            if not freecam then return end
            freecam = false
            gui.Enabled = false

            if conn then
                conn:Disconnect()
                conn = nil
            end

            -- FIX: Karakteri geri aç
            root.Anchored = false
            fixLegs()

            cam.CameraType = Enum.CameraType.Custom
            UserInputService.MouseBehavior = Enum.MouseBehavior.Default
        end

        tool.Equipped:Connect(enableFreecam)
        tool.Unequipped:Connect(disableFreecam)
    end
})

scriptsTab:AddSection({ "🚁 Drone Xeno" })

scriptsTab:AddButton({
    Name = "🚁 Xeno Drone",
    Callback = function()
        loadstring(game:HttpGet("https://raw.githubusercontent.com/EgeKazak1/Xeno-Hub-Drone/main/main"))()
    end
})

--[[
    ULTIMATE ALL-ACCESS & HYPERION BYPASS SCRIPT
    
    Kapsam:
    - Hyperion (Byfron) & Maxy Anticheat Bypass
    - Tüm Gamepass & VIP İçerikleri (GamepassController & Gamepasses.txt)
    - Premium Araç Kontrolleri & Hız Sınırı Kaldırma (Game8Settings.txt)
    - Temalar, Evler ve Gizli Menülerin Açılması (ThemesMenu.txt)
    - Remote Event Manipülasyonu (FireServer/Remotes)
]]

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- 1. [HYPERION / MAXY BYPASS] 
-- Anticheat sistemlerinin namecall ve hook metodlarını manipüle eder.
if getgenv and hookmetatable then
    local oldNamecall
    oldNamecall = hookmetatable(game, {
        __namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            -- Anticheat remote'larını sustur (Maxy/Byfron tespiti için)
            if method == "FireServer" and (tostring(self):find("Anticheat") or tostring(self):find("1Max")) then
                return nil 
            end
            
            -- Teleport veya hız tespiti yapan invoke'ları engelle
            if method == "InvokeServer" and tostring(self):find("Check") then
                return wait(9e9) 
            end
            
            return oldNamecall(self, ...)
        end)
    })
    getgenv().Hyperion_Bypass = true
    getgenv().Maxy_Bypass = true
end

-- 2. [GAMEPASS & VIP BYPASS]
-- GamepassController.txt ve Gamepasses.txt verilerine dayanarak tüm kilitleri açar.
local function bypassGamepasses()
    local GPCPath = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Client"):WaitForChild("UI"):WaitForChild("Gamepass"):WaitForChild("GamepassController")
    local GPC = require(GPCPath)
    
    if GPC and GPC.IsOwned then
        -- Tüm gamepass sorgularına true döndür
        GPC.IsOwned = function() return true end
    end
    
    -- Gift ve Name sorgularını da manipüle et
    local Gamepasses = require(ReplicatedStorage.Modules.Shared.PlayerData.Gamepasses)
    if Gamepasses then
        Gamepasses.GetName = function(id) return "Unlocked Premium" end
        Gamepasses.GiftExists = function() return true end
    end
    print("[SUCCESS] Tüm Gamepass ve VIP kilitleri bypass edildi.")
end
task.spawn(bypassGamepasses)

-- 3. [VEHICLE & SPEED BYPASS]
-- Game8Settings.txt içindeki tüm hız limitlerini ve bekleme sürelerini sıfırlar.
local function bypassSettings()
    -- ReplicatedStorage içindeki Game8Settings modülünü bulur
    for _, v in pairs(game:GetDescendants()) do
        if v.Name == "Game8Settings" and v:IsA("ModuleScript") then
            local Settings = require(v)
            Settings.CarMaxSpeedRegularPlayer = 9999
            Settings.CarMaxSpeedPass200 = 9999
            Settings.CarMaxSpeedPassLower = 9999
            Settings.VIPCarCoolDown = 0
            Settings.CarCoolDown = 0
            Settings.HorseMaxSpeed = 500
            print("[SUCCESS] Araç hız limitleri ve cooldownlar kaldırıldı.")
        end
    end
end
task.spawn(bypassSettings)

-- 4. [PREMIUM CONTROLS & THEMES]
-- VehiclePremiumControlsButton.txt ve ThemesMenu.txt mantığını kullanarak gizli panelleri açar.
local function unlockInterfaces()
    -- Araç premium panellerini görünür kıl (Tag ekleyerek)
    for _, v in pairs(game:GetDescendants()) do
        if v:IsA("ObjectValue") and v.Name == "Panel" then
            pcall(function()
                v.Parent:AddTag("Panel")
            end)
        end
    end
    
    -- Temalar ve Evler için kilitli durumları kaldır
    local Unlockable = require(ReplicatedStorage.Modules.Client.PlayerData.UnlockableController)
    if Unlockable then
        Unlockable.IsUnlocked = function() return true end
    end
end
task.spawn(unlockInterfaces)

-- 5. [REMOTE CONNECTION & COMMANDS]
-- FireServer bağlantılı komutlar ve Remote Event yöneticisi.
local RemoteManager = {
    RE = ReplicatedStorage:FindFirstChild("RE"),
    Fire = function(self, name, ...)
        if self.RE and self.RE:FindFirstChild(name) then
            self.RE[name]:FireServer(...)
        end
    end
}

-- Bağlantılı Komut Örnekleri (Kullanım: RemoteManager:Fire("RemoteAdı", args))
task.spawn(function()
    -- Sunucuya tüm gamepasslerin sahip olunduğunu "bağlantılı komut" olarak bildir
    RemoteManager:Fire("1Gam1ePas1sServe1r", "ValidateAll")
    -- Hız paketini aktif et
    RemoteManager:Fire("1Faste1r", true)
end)

