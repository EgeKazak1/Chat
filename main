-- Meslek Ayarlama Fonksiyonu (Resmi Remotelar kullanılarak)
local function SetJob(jobName, jobIcon)
    -- Brookhaven'ın orijinal iş verme ve çıkma sistemini tetikler
    -- jobnam.txt'deki Remotes.fireServer("GiveJobUIMenu", jobName) mantığı
    
    pcall(function()
        -- Önce varsa mevcut işten çık (Temiz geçiş için)
        Remotes.fireServer("QuitJob", jobName)
        task.wait(0.1)
        -- Yeni işi resmi olarak al
        Remotes.fireServer("GiveJobUIMenu", jobName)
    end)

    -- Ek görsel güncelleme (Billboard/Kafa Yazısı için ekstra kontrol)
    local char = plr.Character
    if char and char:FindFirstChild("Head") then
        for _, gui in ipairs(char.Head:GetChildren()) do
            if gui:IsA("BillboardGui") and (gui.Name:lower():find("job") or gui.Name:lower():find("rank")) then
                local textLabel = gui:FindFirstChildWhichIsA("TextLabel")
                local imageLabel = gui:FindFirstChildWhichIsA("ImageLabel")
                if textLabel then textLabel.Text = jobName end
                if imageLabel then imageLabel.Image = "rbxassetid://" .. jobIcon end
            end
        end
    end
    
    print("Resmi Brookhaven Mesleği Seçildi: " .. jobName)
    JobMenu.Visible = false
end

-- Butonları Oluşturma (İkonlu)
for i, data in ipairs(JobsData) do
    local container = Instance.new("TextButton")
    container.Size = UDim2.new(1, -15, 0, 35)
    container.Position = UDim2.new(0, 7, 0, (i-1) * 40)
    container.BackgroundColor3 = (data.Name == "VIP") and Color3.fromRGB(180, 140, 0) or Color3.fromRGB(40, 40, 40)
    container.BorderSizePixel = 0
    container.Text = "" 
    container.Parent = JobMenu
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6)

    -- Meslek İkonu
    local iconImg = Instance.new("ImageLabel")
    iconImg.Size = UDim2.new(0, 25, 0, 25)
    iconImg.Position = UDim2.new(0, 5, 0.5, -12)
    iconImg.BackgroundTransparency = 1
    iconImg.Image = "rbxassetid://" .. data.Icon
    iconImg.Parent = container

    -- Meslek Metni
    local jobText = Instance.new("TextLabel")
    jobText.Size = UDim2.new(1, -40, 1, 0)
    jobText.Position = UDim2.new(0, 35, 0, 0)
    jobText.BackgroundTransparency = 1
    jobText.Text = data.Name
    jobText.TextColor3 = Color3.new(1, 1, 1)
    jobText.Font = Enum.Font.GothamMedium
    jobText.TextSize = 12
    jobText.TextXAlignment = Enum.TextXAlignment.Left
    jobText.Parent = container

    container.MouseButton1Click:Connect(function()
        SetJob(data.Name, data.Icon)
    end)
end

--[[
    BROOKHAVEN CMDR TERMINAL & FULL REPLICA TRIGGER
    Açıklama: Brookhaven'ın dahili Cmdr ve Replica sistemlerini tam kapasite tetikler.
    Permission ve Server-Side tetiklemeleri için Replica Remote'larını kullanır.
]]

local plr = game:GetService("Players").LocalPlayer
local rs = game:GetService("ReplicatedStorage")
local uis = game:GetService("UserInputService")

-- Brookhaven Resmi Paketleri, Remotelar ve Replica Modülleri
local Packages = rs:WaitForChild("Packages")
local Remotes = require(Packages:WaitForChild("Remotes"))

-- Replica Tetikleyicisi (Brookhaven'ın veri senkronizasyon sistemi)
-- ReplicaService genellikle ReplicaRemoteEvents üzerinden çalışır
local ReplicaRemote = rs:FindFirstChild("ReplicaRemoteEvents") or rs:FindFirstChild("Replica_RemoteEvent")

-- GUI Oluşturma
local CmdrBtn = Instance.new("TextButton")
CmdrBtn.Name = "OpenOfficialCmdr"
CmdrBtn.Size = UDim2.new(0.96, 0, 0, 45)
CmdrBtn.BackgroundColor3 = Color3.fromRGB(30, 0, 60) -- Koyu Terminal Moru
CmdrBtn.BorderSizePixel = 0
CmdrBtn.Text = "⌨️ CMDR TERMINAL (FULL REPLICA)"
CmdrBtn.TextColor3 = Color3.new(1, 1, 1)
CmdrBtn.Font = Enum.Font.Code
CmdrBtn.TextSize = 13
CmdrBtn.Parent = LeftFrame -- GUI panelinizin yolu

local corner = Instance.new("UICorner", CmdrBtn)
corner.CornerRadius = UDim.new(0, 8)

-- Cmdr ve Replica Tetikleme Fonksiyonu
local function TriggerOfficialCmdr()
    print("Brookhaven Cmdr & Replica Tetikleniyor...")

    -- 1. ADIM: Permission (Yetki) ve Replica Senkronizasyonu
    -- ReplicaService üzerinden sunucuya (ServerScriptService tetiklemesi gibi) veri gönderilir
    pcall(function()
        if ReplicaRemote then
            -- Brookhaven'ın yetki verilerini Replica üzerinden güncelleme denemesi
            -- Bu, sunucu tarafında "Yetkili" bayrağını tetikler
            Remotes.fireServer("Replica_RequestValue", {
                Type = "PermissionUpdate",
                Key = "AdminLevel",
                Value = 5 -- En üst yetki seviyesi
            })
        end
        
        -- Resmi yetki ve Cmdr açılış senkronizasyonu
        Remotes.fireServer("CheckPermission", "Cmdr")
        Remotes.fireServer("AdminRequest", "Console")
        Remotes.fireServer("CmdrRemoteEvent", {
            Action = "Open",
            Source = "AdminUI"
        })
    end)

    -- 2. ADIM: Cmdr UI'ı (Client) Zorla Çağırma
    pcall(function()
        -- Cmdr paketini modül olarak yükle ve 'Show' metodunu çağır
        local CmdrModule = rs:FindFirstChild("Cmdr", true)
        if CmdrModule then
            local CmdrClient = require(CmdrModule:WaitForChild("CmdrClient"))
            if CmdrClient then
                -- Eğer arayüz kapalıysa zorla açar, açıksa gizler
                CmdrClient:Show() 
            end
        end
    end)
    
    -- 3. ADIM: ServerScriptService Tetiklemesi İçin Remote Invoke
    -- Bazı Brookhaven sürümlerinde Cmdr açılışı bir Function (Invoke) gerektirir
    task.spawn(function()
        pcall(function()
            local cmdrFunc = rs:FindFirstChild("GetCmdrPermissions", true)
            if cmdrFunc and cmdrFunc:IsA("RemoteFunction") then
                cmdrFunc:InvokeServer()
            end
        end)
    end)
end

-- Buton Tıklama
CmdrBtn.MouseButton1Click:Connect(function()
    TriggerOfficialCmdr()
    
    -- Efekt
    CmdrBtn.Text = "EXECUTING CMDR..."
    CmdrBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 200)
    task.wait(1)
    CmdrBtn.Text = "⌨️ CMDR TERMINAL (FULL REPLICA)"
    CmdrBtn.BackgroundColor3 = Color3.fromRGB(30, 0, 60)
end)

-- F2 Kısayol Desteği
uis.InputBegan:Connect(function(input, gpe)
    if not gpe and input.KeyCode == Enum.KeyCode.F2 then
        TriggerOfficialCmdr()
    end
end)

print("Cmdr Replica Script Yüklendi. Tetiklemek için butona basın veya F2 kullanın.")
        -- 6. ARAÇLAR (Car Spawner - Daha Küçük Liste)

        -- === START: GetCar compatibility helper ===
        local function spawnCarFixed(carName)
            local remote = ReplicatedStorage:FindFirstChild("RE") or ReplicatedStorage:FindFirstChild("Remotes") or ReplicatedStorage

            -- 1) Try original VehicleSpawn
            pcall(function()
                if remote and remote:FindFirstChild("VehicleSpawn") and remote.VehicleSpawn.FireServer then
                    remote.VehicleSpawn:FireServer(carName)
                end
            end)

            -- 2) Try common alternative GetCar/Get_Car names
            pcall(function()
                local candidates = {"GetCar", "Get_Car", "GetCarToServer", "GetCarServer"}
                for _, name in ipairs(candidates) do
                    local r = remote:FindFirstChild(name)
                    if r and r.FireServer then
                        r:FireServer(carName)
                        break
                    end
                end
            end)

            -- 3) Brookhaven-style fallback (1Ca1r expects PickingCar)
            pcall(function()
                local r = remote:FindFirstChild("1Ca1r")
                if r and r.FireServer then
                    r:FireServer("PickingCar", carName)
                end
            end)

            -- 4) Generic trigger fallback
            pcall(function()
                local trigger = remote:FindFirstChild("1Playe1rTrigge1rEven1t") or remote:FindFirstChild("1PlayerTriggerEvent") or remote:FindFirstChild("RemoteEvent") or remote:FindFirstChild("GetItem")
                if trigger and trigger.FireServer then
                    local args = { [1] = "AcceptedToolToServer", [2] = carName, [3] = game:GetService("Players").LocalPlayer }
                    trigger:FireServer(unpack(args))
                end
            end)
        end
        -- === END: GetCar compatibility helper ===

        local vehicles = {"RollsRoyce", "SemiPass", "DragBike", "CopChallenger", "CopLambo", "Halloween2025GhostBikeFire", "Halloween2025CoffinCarPumpkin", "PajeroSUV", "Ambulance", "KeiTruck", "FireTruck", "67FordTruck"}
        for _, car in pairs(vehicles) do
            local cBtn = Instance.new("TextButton")
            cBtn.Size = UDim2.new(0.96, 0, 0, 32)
            cBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
            cBtn.Text = car
            cBtn.TextColor3 = Color3.new(1, 1, 1)
            cBtn.Font = Enum.Font.Gotham
            cBtn.Parent = RightFrame
            Instance.new("UICorner", cBtn)
            cBtn.MouseButton1Click:Connect(function()
                pcall(function()
                    spawnCarFixed(car)
                end)
            end)
        end

        -- DÖNGÜ: İSİM RENKLENDİRME (VIP)
        spawn(function()
            while ScreenGui and ScreenGui.Parent do
                local char = LocalPlayer.Character
                if char then
                    for _, l in pairs(char:GetDescendants()) do
                        if l:IsA("TextLabel") then
                            if _G.VipMode == "Gold" then l.TextColor3 = Color3.fromRGB(255, 215, 0)
                            elseif _G.VipMode == "Diamond" then l.TextColor3 = Color3.fromRGB(0, 255, 255)
                            elseif _G.VipMode == "Rainbow" then l.TextColor3 = Color3.fromHSV(tick() % 5 / 5, 0.8, 1) end
                        end
                    end
                end
                RunService.RenderStepped:Wait()
            end
        end)
    end
})

Tab:AddButton({
    Title = "💸 Money Gun",
    Locked = false,
    Callback = function()
        local rep = game:GetService("ReplicatedStorage")
        local Players = game:GetService("Players")
        local localPlayer = Players.LocalPlayer
        local itemName = "MoneyGun"

        local function tryNotify(title, text)
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = title,
                    Text = text,
                    Duration = 4
                })
            end)
        end

        local ok, err = pcall(function()
            local re = rep:FindFirstChild("RE") or rep:FindFirstChild("Remotes") or rep
            local candidates = {"GetItem", "Getİtem", "Get_Item", "GetTool", "GetToolToServer"}

            for _, name in ipairs(candidates) do
                local r = re:FindFirstChild(name)
                if r then
                    if r.InvokeServer then
                        r:InvokeServer(itemName)
                        tryNotify("💸 Money Gun", "Requested via "..name.." ⚡")
                        return
                    elseif r.FireServer then
                        r:FireServer(itemName)
                        tryNotify("💸 Money Gun", "Requested via "..name.." 🔥")
                        return
                    end
                end
            end

            local trigger = re:FindFirstChild("1Playe1rTrigge1rEven1t") or rep:FindFirstChild("1Playe1rTrigge1rEven1t")
            if trigger then
                local args = {
                    [1] = "AcceptedToolToServer",
                    [2] = itemName,
                    [3] = localPlayer
                }

                if trigger.FireServer then
                    trigger:FireServer(unpack(args))
                    tryNotify("💸 Money Gun", "Triggered successfully 🎯")
                    return
                elseif trigger.InvokeServer then
                    trigger:InvokeServer(unpack(args))
                    tryNotify("💸 Money Gun", "Triggered successfully ⚙️")
                    return
                end
            end

            local topRemotes = rep:FindFirstChild("Remotes")
            if topRemotes then
                local r = topRemotes:FindFirstChild("GetItem") or topRemotes:FindFirstChild("Getİtem")
                if r and r.FireServer then
                    r:FireServer(itemName)
                    tryNotify("💸 Money Gun", "Requested via Remotes 📡")
                    return
                end
            end

            tryNotify("💸 Money Gun", "No suitable remote found ❌")
        end)

        if not ok then
            tryNotify("💸 Money Gun", "Error: "..tostring(err).." ⚠️")
        end
    end
})

