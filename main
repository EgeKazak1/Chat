    Name = "🎯 Apply Single Selected Part",
    Callback = function()
        local args = {[1] = {0,0,0,0,0,0}}
        local indexMap = {Torso=1, RightArm=2, LeftArm=3, RightLeg=4, LeftLeg=5, Head=6}
        local idx = indexMap[_G.selectedCategory]
        
        args[1][idx] = _G.selectedParts[_G.selectedCategory]
        Remotes.ChangeCharacterBody:InvokeServer(unpack(args))
    end
})

Tab:AddButton({
    Name = "🚀 Apply All Custom Parts",
    Callback = function()
        local args = {[1] = {
            _G.selectedParts.Torso, _G.selectedParts.RightArm, _G.selectedParts.LeftArm,
            _G.selectedParts.RightLeg, _G.selectedParts.LeftLeg, _G.selectedParts.Head
        }}
        Remotes.ChangeCharacterBody:InvokeServer(unpack(args))
        Notify("Updated", "All custom body parts applied.")
    end
})

