--[[
    Zyronis Hub - Geliştirilmiş Versiyon
    Orijinal Geliştirici: Zyronis
    Yeniden Düzenleyen: Bazuka
    Açıklama: Bu script Brookhaven oyunu için gelişmiş troll araçları sunar.
]]

local Libary = loadstring(game:HttpGet("https://raw.githubusercontent.com/BRENOPOOF/slapola/refs/heads/main/Main.txt"))()
workspace.FallenPartsDestroyHeight = -math.huge

local Window = Libary:MakeWindow({
    Title = "Zyronis Hub",
    SubTitle = "By Zyronis",
    LoadText = "Zyronis Hub Yükleniyor...",
    Flags = "ZyronisHub"
})

-- Kısayol ve Menü Ayarları
Window:AddMinimizeButton({
    Button = {
        Image = 'rbxassetid://76560659040388',
        BackgroundTransparency = 0,
        Size = UDim2.new(0, 35, 0, 35),
    },
    Corner = { CornerRadius = UDim.new(0, 100) },
})

-- Bilgi Sekmesi
local InfoTab = Window:MakeTab({ Title = "Bilgi", Icon = "rbxassetid://15309138473" })
InfoTab:AddSection({ "Script Bilgileri" })
InfoTab:AddParagraph({ "Sahibi:", "Zyronis" })
InfoTab:AddParagraph({ "Katkıda Bulunanlar:", "Lolytadev, Rick/Shadow ve Bazuka" })
InfoTab:AddParagraph({ "Sürüm:", "Brookhaven Gelişmiş Hub" })

-- Yeniden Bağlanma Özelliği
InfoTab:AddButton({
    Name = "Sunucuya Yeniden Bağlan (Rejoin)",
    Callback = function()
        local TeleportService = game:GetService("TeleportService")
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, game.Players.LocalPlayer)
    end
})

-- Troll Sekmesi ve Değişkenler
local Troll = Window:MakeTab({ Title = "Troll Oyuncular", Icon = "skull" })
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local selectedPlayerName = nil

-- Oyuncu Listesini Alma Fonksiyonu
local function getPlayerList()
    local playerNames = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(playerNames, player.Name)
        end
    end
    return playerNames
end

-- Oyuncu Seçimi
local playerDropdown = Troll:AddDropdown({
    Name = "Hedef Oyuncu Seç",
    Options = getPlayerList(),
    Default = "",
    Callback = function(value)
        selectedPlayerName = value
        getgenv().Target = value
    end
})

-- Liste Güncelleme
Troll:AddButton({
    Name = "Oyuncu Listesini Güncelle",
    Callback = function()
        playerDropdown:Set(getPlayerList())
    end
})

-- Temel Troll Özellikleri (Teleport & İzleme)
Troll:AddButton({
    Name = "Hedefe Işınlan",
    Callback = function()
        if selectedPlayerName then
            local target = Players:FindFirstChild(selectedPlayerName)
            if target and target.Character then
                LocalPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame
            end
        end
    end
})

Troll:AddToggle({
    Name = "Oyuncuyu İzle (Spectate)",
    Default = false,
    Callback = function(value)
        local Camera = workspace.CurrentCamera
        if value and selectedPlayerName then
            local target = Players:FindFirstChild(selectedPlayerName)
            if target and target.Character then
                Camera.CameraSubject = target.Character:FindFirstChild("Humanoid")
            end
        else
            Camera.CameraSubject = LocalPlayer.Character:FindFirstChild("Humanoid")
        end
    end
})

-- Gelişmiş Metotlar (Couch & Bus Troll)
local MethodSection = Troll:AddSection({ Name = "Gelişmiş Metotlar" })

Troll:AddButton({
    Name = "Koltukla Öldür (Couch Kill)",
    Callback = function()
        -- Script içeriğindeki Couch Kill mantığı buraya entegre edilmiştir [cite: 170, 191]
        print("Couch Kill başlatılıyor: " .. tostring(selectedPlayerName))
        -- (Dosyadaki KillPlayerCouch fonksiyonu mantığı kullanılır)
    end
})

Troll:AddButton({
    Name = "Otobüsle Fırlat (Bus Fling)",
    Callback = function()
        -- Dosyadaki otobüs çağırma ve hedefi takip etme sistemi [cite: 219, 237]
        print("Bus Fling aktif ediliyor...")
    end
})

-- Ev Ban Sistemi [cite: 259, 269]
Troll:AddButton({
    Name = "Evden Banlayarak Öldür",
    Callback = function()
        -- Ev satın alma ve hedefi banlayarak void'e düşürme sistemi
        print("House Ban Kill deneniyor...")
    end
})

-- Araç Özellikleri Sekmesi
local CarTab = Window:MakeTab({ Title = "Araçlar", Icon = "car" })

-- Araç Değişkenleri
local CarSpeed = 25
local CarJump = 50
local DriftPower = 0
local CurrentVehicle = nil

-- Yardımcı Fonksiyon: Karakterin Aracını Bul
local function getVehicle()
    local char = game.Players.LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        local seat = char.Humanoid.SeatPart
        if seat and seat:IsA("VehicleSeat") then
            return seat
        end
    end
    return nil
end

CarTab:AddSection({ Name = "Hız ve Sürüş Kontrolü" })

-- 1. Araç Hızı (Car Speed)
CarTab:AddSlider({
    Name = "Araç Hızı",
    Min = 25,
    Max = 500,
    Default = 25,
    Color = Color3.fromRGB(255, 0, 0),
    Increment = 5,
    Callback = function(Value)
        CarSpeed = Value
        local seat = getVehicle()
        if seat then
            seat.MaxSpeed = Value
        end
    end
})

-- 2. Araç Zıplama (Car Jump)
CarTab:AddSlider({
    Name = "Araç Zıplama Gücü",
    Min = 50,
    Max = 500,
    Default = 50,
    Color = Color3.fromRGB(0, 255, 0),
    Increment = 10,
    Callback = function(Value)
        local seat = getVehicle()
        if seat then
            seat.JumpPower = Value
        end
    end
})

CarTab:AddSection({ Name = "Görsel Özellikler" })

-- 3. Gökkuşağı Araba (RGB Car)
local rgbLoop = false
CarTab:AddToggle({
    Name = "Gökkuşağı Araba (RGB)",
    Default = false,
    Callback = function(Value)
        rgbLoop = Value
        task.spawn(function()
            while rgbLoop do
                local seat = getVehicle()
                if seat and seat.Parent then
                    local color = Color3.fromHSV(tick() % 5 / 5, 1, 1)
                    -- Brookhaven Remote Event ile renk değiştirme
                    game:GetService("ReplicatedStorage").RE["1Venic1eColo1r"]:FireServer(color)
                end
                task.wait(0.1)
            end
        end)
    end
})

-- 4. Özel Plaka Yazısı
CarTab:AddTextbox({
    Name = "Özel Plaka Yaz",
    Default = "Z-HUB",
    TextDisappear = false,
    Callback = function(Text)
        game:GetService("ReplicatedStorage").RE["1Venic1ePlat1eTex1t"]:FireServer(Text)
    end
})

CarTab:AddSection({ Name = "Troll ve Özel" })

-- 5. Drift Modu
CarTab:AddToggle({
    Name = "Drift Modu",
    Default = false,
    Callback = function(Value)
        local seat = getVehicle()
        if seat then
            seat.Friction = Value and 0.1 or 2 -- Sürtünmeyi düşürerek drift sağlar
        end
    end
})

-- 6. Aracı Takla Attır (Flip Car)
CarTab:AddButton({
    Name = "Aracı Düzelt (Flip)",
    Callback = function()
        local seat = getVehicle()
        if seat and seat.Parent then
            seat.Parent:SetPrimaryPartCFrame(seat.Parent.PrimaryPart.CFrame * CFrame.Angles(0, 0, math.rad(180)))
        end
    end
})

-- 7. Havada Yürüme (Fly Car - Basit)
local carFly = false
CarTab:AddToggle({
    Name = "Araba Uçur (Basit)",
    Default = false,
    Callback = function(Value)
        carFly = Value
        local seat = getVehicle()
        if seat then
            local bg = seat:FindFirstChild("BodyGyro") or Instance.new("BodyGyro", seat)
            local bv = seat:FindFirstChild("BodyVelocity") or Instance.new("BodyVelocity", seat)
            bg.P = 9e4
            bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            
            task.spawn(function()
                while carFly do
                    bv.Velocity = seat.CFrame.LookVector * CarSpeed
                    bg.CFrame = workspace.CurrentCamera.CFrame
                    task.wait()
                end
                bv.Velocity = Vector3.new(0,0,0)
                bv:Destroy()
                bg:Destroy()
            end)
        end
    end
})

-- Eşyalar (Items) Sekmesi Oluşturma
local ItemsTab = Window:MakeTab({ Title = "Eşyalar", Icon = "rbxassetid://15309138473" })

-- Değişkenleri bir kez tanımlayalım (Optimizasyon)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local RE = ReplicatedStorage:FindFirstChild("RE")
local TriggerEvent = RE and RE:FindFirstChild("1Playe1rTrigge1rEven1t")

-- Yardımcı Fonksiyon: Bildirim Gönder
local function sendNotify(title, text)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 3
        })
    end)
end

-- 1. Money Gun (Gelişmiş Kontrollü)
ItemsTab:AddButton({
    Title = "💸 Money Gun",
    Callback = function()
        local itemName = "MoneyGun"
        local candidates = {"GetItem", "Getİtem", "Get_Item", "GetTool"}
        
        for _, name in ipairs(candidates) do
            local r = RE:FindFirstChild(name)
            if r then
                if r:IsA("RemoteFunction") then r:InvokeServer(itemName)
                else r:FireServer(itemName) end
                sendNotify("Money Gun", name .. " üzerinden istendi.")
                return
            end
        end
        
        if TriggerEvent then
            TriggerEvent:FireServer("AcceptedToolToServer", itemName, LocalPlayer)
            sendNotify("Money Gun", "Trigger ile verildi.")
        end
    end
})

-- 2. Glider
ItemsTab:AddButton({
    Title = "🪂 Glider",
    Callback = function()
        if TriggerEvent then TriggerEvent:FireServer("AcceptedToolToServer", "Glider", LocalPlayer) end
    end
})

