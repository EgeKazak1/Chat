    ClearText = false,
    Callback = function(text)
        if text and text:gsub(" ", ""):len() > 0 then
            local cleanId = text:match("%d+")
            if cleanId then
                CurrentDecal = cleanId
            end
        end
    end
})

CarTab:AddButton({
    Name = "✅ Apply Decal",
    Callback = function()
