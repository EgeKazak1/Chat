-- 2. DEX VE DOSYA KONTROLLÜ STOK ÇEKİCİ
local function FetchLiveStock(shopId)
    local results = {}
    local remoteFunction = ReplicatedStorage:WaitForChild("RemoteEvents"):FindFirstChild("GetShopData")
    
    -- Decompile dosyalarındaki InvokeServer(shopId) mantığı
    if remoteFunction and remoteFunction:IsA("RemoteFunction") then
        local success, data = pcall(function()
            return remoteFunction:InvokeServer(shopId)
        end)
        
        if success and data then
            for name, details in pairs(data) do
                -- Dosyadaki StockAmount veya Amount kontrolü
                results[name] = details.Amount or (details.StockAmount and details.StockAmount[1]) or 0
            end
        end
    end

    -- Yedek plan: Eğer sunucu veri vermezse dosyalarındaki isimleri çek
    if next(results) == nil then
        local moduleName = (shopId == "SeedShop") and "SeedShopData" or "GearShopData"
        local module = ReplicatedStorage:FindFirstChild("Shop") and ReplicatedStorage.Shop:FindFirstChild("ShopData") and ReplicatedStorage.Shop.ShopData:FindFirstChild(moduleName)
        
        if module then
            local static = require(module)
            for key, val in pairs(static.ShopData) do
                results[val.Name or key] = "Kontrol Ediliyor..."
            end
        end
    end
    
    return results
end

-- 3. WEBHOOK GÖNDERİMİ (Bot Formatı)
local function PostToDiscord(seeds, gears)
    local seedContent = ""
    local gearContent = ""

    for n, q in pairs(seeds) do seedContent = seedContent .. "🌱 **" .. n .. "**: `" .. tostring(q) .. "`\n" end
    for n, q in pairs(gears) do gearContent = gearContent .. "⚙️ **" .. n .. "**: `" .. tostring(q) .. "`\n" end

    local embed = {
        ["title"] = "📦 Garden Horizons - Stok Botu Raporu",
        ["description"] = "Sunucu RemoteFunction (GetShopData) üzerinden çekilmiştir.",
        ["color"] = 0x00FF7F,
        ["fields"] = {
            {["name"] = "Tohumlar", ["value"] = seedContent ~= "" and seedContent or "Bulunamadı", ["inline"] = true},
            {["name"] = "Ekipmanlar", ["value"] = gearContent ~= "" and gearContent or "Bulunamadı", ["inline"] = true}
        },
        ["footer"] = {["text"] = "Bypass Mode: Active | Alchemy Hub"}
    }

    local req = (syn and syn.request or http_request or request)
    if req then
        req({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({["embeds"] = {embed}})
        })
    end
end

-- 4. RAYFIELD HUB BAŞLATMA
local function LoadHub()
    local Window = Rayfield:CreateWindow({
        Name = "Alchemy Stock Hub",
        LoadingTitle = "Bypassing Game Controllers...",
        ConfigurationSaving = { Enabled = false }
    })

    local MainTab = Window:CreateTab("📊 Canlı Stoklar", 4483362458)
    
    task.spawn(function()
        while true do
            local seeds = FetchLiveStock("SeedShop")
            local gears = FetchLiveStock("GearShop")
            
            PostToDiscord(seeds, gears)
            
            Rayfield:Notify({
                Title = "Stok Botu",
                Content = "Veriler Discord kanalına gönderildi.",
                Duration = 3
            })
            
            task.wait(CHECK_INTERVAL)
        end
    end)
end

-- 5. DOĞRULAMA MANTIĞI
VerifyBtn.MouseButton1Click:Connect(function()
    if tonumber(Answer.Text) == dogru_cevap then
        ScreenGui:Destroy()
        LoadHub()
    else
        VerifyBtn.Text = "HATALI CEVAP"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(1)
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        VerifyBtn.Text = "BOTU TETİKLE"
    end
end)
