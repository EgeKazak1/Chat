-- Arayüz Kütüphanesi Yükleniyor
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Xeno Hub | Brookhaven FULL 🏆",
   LoadingTitle = "Xeno Team Premier Yükleniyor...",
   LoadingSubtitle = "by Xeno Team",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "XenoConfigs",
      FileName = "XenoFull"
   },
   KeySystem = false 
})

-- Servisler ve Değişkenler
local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local RootPart = Character:WaitForChild("HumanoidRootPart")
local RS = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")
local TeleportService = game:GetService("TeleportService")

-- Durum Değişkenleri
_G.TargetPlayer = ""
_G.LoopBomb = false
_G.AntiSit = false
_G.RainbowCar = false

-- Yardımcı Fonksiyonlar
local function GetPlayer(name)
    name = name:lower()
    for _, v in pairs(game.Players:GetPlayers()) do
        if v.Name:lower():find(name) or v.DisplayName:lower():find(name) then
            return v
        end
    end
    return nil
end

-- SEKME YAPILARI
local MainTab = Window:CreateTab("Oyuncu Troll", 4483362458)
local WorldTab = Window:CreateTab("Dünya & Ev", 4483362458)
local VehicleTab = Window:CreateTab("Araçlar", 4483362458)
local VisualsTab = Window:CreateTab("Görsel & Avatar", 4483362458)
local MiscTab = Window:CreateTab("Sistem", 4483362458)

-- OYUNCU TROLL SEKMESİ
MainTab:CreateSection("Hedef Ayarları")

MainTab:CreateInput({
   Name = "Hedef Oyuncu",
   PlaceholderText = "İsim veya Görünen Ad...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      _G.TargetPlayer = Text
   end,
})

MainTab:CreateSection("İmha & Troll Metodları")

MainTab:CreateButton({
   Name = "Couch Kill (Kanepe ile Boşluğa)",
   Callback = function()
      local target = GetPlayer(_G.TargetPlayer)
      if target and target.Character then
         Rayfield:Notify({Title = "İşlem Başladı", Content = target.DisplayName .. " hedefleniyor...", Duration = 2})
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer("Couch", target.Character.HumanoidRootPart.CFrame)
         task.wait(0.3)
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer("Couch", CFrame.new(0, -999, 0))
      end
   end,
})

MainTab:CreateButton({
   Name = "Bus Kill (Okul Otobüsü)",
   Callback = function()
      local target = GetPlayer(_G.TargetPlayer)
      if target then
         RS:WaitForChild("RE"):WaitForChild("s1chool1bus"):FireServer(target.Name)
         task.wait(0.6)
         RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer("SetVehicleCFrame", CFrame.new(0, 5000, 0))
      end
   end,
})

MainTab:CreateButton({
   Name = "House Ban Kill (Evin İçinde)",
   Callback = function()
      local target = GetPlayer(_G.TargetPlayer)
      if target then
         RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("BanUser", target)
         Rayfield:Notify({Title = "Ban Atıldı", Content = "Hedef evden uzaklaştırıldı.", Duration = 2})
      end
   end,
})

MainTab:CreateButton({
   Name = "Yanına Çek (Bring Player)",
   Callback = function()
      local target = GetPlayer(_G.TargetPlayer)
      if target and target.Character then
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer("Couch", target.Character.HumanoidRootPart.CFrame)
         task.wait(0.3)
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer("Couch", RootPart.CFrame)
      end
   end,
})

MainTab:CreateButton({
   Name = "İzle (Spectate)",
   Callback = function()
      local target = GetPlayer(_G.TargetPlayer)
      if target and target.Character then
         workspace.CurrentCamera.CameraSubject = target.Character.Humanoid
      end
   end,
})

-- DÜNYA & EV SEKMESİ
