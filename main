local isColorChanging = false
local function changeCarColor()
    while isColorChanging do
        local hue = (tick() % 5) / 5
        local color = Color3.fromHSV(hue, 1, 1)
        pcall(function()
            ReplicatedStorage.RE["1Venic1eColo1r"]:FireServer(color)
        end)
        task.wait(0.15) -- Smooth and safe delay
    end
end

CarTab:AddToggle({
    Name = "Rainbow Car RGB",
    Default = false,
    Callback = function(state)
        isColorChanging = state
        if isColorChanging then
            task.spawn(changeCarColor)
        end
    end
})

