-- 2. DEX & DECOMPILED DATA CONTROLLER
-- Dosyalarındaki "GetShopData" RemoteFunction'ını kullanarak gerçek zamanlı stok çeker.
local function GetLiveStock(shopType) -- "SeedShop" veya "GearShop"
    local stockResult = {}
    local remote = ReplicatedStorage:WaitForChild("RemoteEvents"):FindFirstChild("GetShopData")
    
    if remote and remote:IsA("RemoteFunction") then
        local success, data = pcall(function()
            return remote:InvokeServer(shopType)
        end)
        
        if success and data then
            for itemName, itemDetails in pairs(data) do
                -- Dosyalarındaki StockAmount yapısını kontrol eder
                stockResult[itemName] = itemDetails.Amount or 0
            end
        end
    end
    
    -- Eğer Remote başarısız olursa, modül dosyalarından statik isimleri çek
    if next(stockResult) == nil then
        local modulePath = shopType == "SeedShop" and "SeedShopData" or "GearShopData"
        local staticData = require(ReplicatedStorage.Shop.ShopData:WaitForChild(modulePath))
        for name, info in pairs(staticData.ShopData) do
            stockResult[info.Name or name] = "Yükleniyor..."
        end
    end
    
    return stockResult
end

-- 3. WEBHOOK BOT FORMATTER
local function SendBotUpdate(seeds, gears)
    local seedStr, gearStr = "", ""
    for k, v in pairs(seeds) do seedStr = seedStr .. "🌱 **" .. k .. "**: `" .. v .. "`\n" end
    for k, v in pairs(gears) do gearStr = gearStr .. "⚙️ **" .. k .. "**: `" .. v .. "`\n" end

    local payload = {
        ["username"] = "Garden Stock Bot",
        ["embeds"] = {{
            ["title"] = "📢 Canlı Mağaza Stok Raporu",
            ["color"] = 0x00FF7F,
            ["fields"] = {
                {["name"] = "Tohumlar (Seeds)", ["value"] = seedStr ~= "" and seedStr or "Veri yok", ["inline"] = true},
                {["name"] = "Ekipmanlar (Gears)", ["value"] = gearStr ~= "" and gearStr or "Veri yok", ["inline"] = true}
            },
            ["footer"] = {["text"] = "Dex & Remote Kontrollü Bot"}
        }}
    }
    
    local req = (syn and syn.request or http_request or request)
    if req then
        req({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end
end

-- 4. RAYFIELD HUB & TETİKLEYİCİ
local function StartBotHub()
    local Window = Rayfield:CreateWindow({
        Name = "Alchemy Stock Hub",
        LoadingTitle = "RemoteEvents Dinleniyor...",
        ConfigurationSaving = { Enabled = false }
    })

    local SeedTab = Window:CreateTab("🌱 Seeds", 4483362458)
    local GearTab = Window:CreateTab("⚙️ Gears", 4483362458)

    task.spawn(function()
        while true do
            local currentSeeds = GetLiveStock("SeedShop")
            local currentGears = GetLiveStock("GearShop")
            
            -- Webhook Gönder
            SendBotUpdate(currentSeeds, currentGears)
            
            -- Rayfield'a Bilgi Ver
            Rayfield:Notify({Title = "Stok Güncellendi", Content = "Discord'a rapor gönderildi.", Duration = 2})
            
            task.wait(60) -- Her dakika kontrol et
        end
    end)
end

-- 5. VERIFICATION
VerifyBtn.MouseButton1Click:Connect(function()
    if tonumber(Input.Text) == dogru_cevap then
        ScreenGui:Destroy()
        StartBotHub()
    else
        VerifyBtn.Text = "YANLIŞ CEVAP!"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(1)
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        VerifyBtn.Text = "DOĞRULA VE BOTU BAĞLA"
    end
end)
