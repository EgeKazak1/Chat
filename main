-- Araba Sekmesi
local CarTab = Window:MakeTab({ Title = "Araçlar", Icon = "car" })
-- ======================================================
-- ADVANCED VEHICLE SETTINGS (ENGLISH & FIXED RGB)
-- ======================================================

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local CurrentDecal = ""
local CurrentVehicleUUID = nil

-- Function: Apply Wheel Decal
local function ApplyDecal(decalId)
    if not CurrentVehicleUUID then return end
    
    local formattedDecal = "http://www.roblox.com/asset/?id=" .. decalId
    
    pcall(function()
        local Remote = ReplicatedStorage.Remotes.SuspensionHeightChanged
        firesignal(Remote.OnClientEvent, CurrentVehicleUUID)
        
        ReplicatedStorage.Remotes.ApplyStateToVehicle:InvokeServer(
            CurrentVehicleUUID,
            {
                ["Lights"] = {
                    ["hazardsActive"] = false,
                    ["lightsOn"] = false,
                },
                ["IsLocked"] = false,
                ["Appearance"] = {
                    ["IsSmoking"] = false,
                    ["SuspensionHeight"] = 1.1,
                    ["BabyCarSeatInstalledNumber"] = 0,
                    ["IsOnFire"] = false,
                    ["WheelDecal"] = formattedDecal,
                },
                ["Performance"] = {
                    ["Turbo"] = 0,
                    ["MaxSpeed"] = 25,
                    ["DriftStrength"] = 1,
                },
                ["Owner"] = LocalPlayer,
            }
        )
    end)
end

-- Track Spawned Vehicle
ReplicatedStorage.Remotes.PlayerSpawnedVehicle.OnClientEvent:Connect(function(data)
    if data and data.uuid then
        CurrentVehicleUUID = data.uuid
    end
end)

-- Section 1: Tire Decal
CarTab:AddSection({ Name = "🛞 Tire Decal" })

CarTab:AddTextBox({
    Name = "Decal ID",
    Description = "Enter Decal ID",
    Default = "",
    PlaceholderText = "Enter ID...",
    ClearText = false,
    Callback = function(text)
        if text and text:gsub(" ", ""):len() > 0 then
            local cleanId = text:match("%d+")
            if cleanId then
                CurrentDecal = cleanId
            end
        end
    end
})

CarTab:AddButton({
    Name = "✅ Apply Decal",
    Callback = function()
        if CurrentDecal and CurrentDecal:len() > 0 then
            ApplyDecal(CurrentDecal)
        end
    end
})

-- Section 2: Spams
local spammingHeadLights = false
local spammingHazardLights = false
local spammingHorn = false

local function spamHeadLights()
    while spammingHeadLights do
        ReplicatedStorage.Remotes.ToggleHeadLights:InvokeServer()
        task.wait(0.1)
    end
end

local function spamHazardLights()
    while spammingHazardLights do
        ReplicatedStorage.Remotes.ToggleHazardLights:InvokeServer()
        task.wait(0.1)
    end
end

local function spamPlayHorn()
    while spammingHorn do
        ReplicatedStorage.Remotes.PlayHorn:InvokeServer()
        task.wait(0.1)
    end
end

CarTab:AddSection({ Name = "🚨 Vehicle Spams" })

CarTab:AddToggle({
    Name = "💡 Spam Headlights",
    Default = false,
    Callback = function(value)
        spammingHeadLights = value
        if spammingHeadLights then
            task.spawn(spamHeadLights)
        else
            task.wait(0.2)
            ReplicatedStorage.Remotes.ToggleHeadLights:InvokeServer()
        end
    end
})

CarTab:AddToggle({
    Name = "🚨 Spam Hazard Lights",
    Default = false,
    Callback = function(value)
        spammingHazardLights = value
        if spammingHazardLights then
            task.spawn(spamHazardLights)
        else
            task.wait(0.2)
            ReplicatedStorage.Remotes.ToggleHazardLights:InvokeServer()
        end
    end
})

CarTab:AddToggle({
    Name = "📢 Spam Horn",
    Default = false,
    Callback = function(value)
        spammingHorn = value
        if spammingHorn then
            task.spawn(spamPlayHorn)
        else
            ReplicatedStorage.Remotes.StopHorn:InvokeServer()
        end
    end
})

-- Section 3: Speed & Turbo
CarTab:AddSection({ Name = "🏎️ Speed Car & Turbo" })

local speedValue = 200
local turboValue = 11.3

local function getAllCars()
    local cars = {}
    if workspace:FindFirstChild("Vehicles") then
        for _, vehicle in pairs(workspace.Vehicles:GetChildren()) do
            if vehicle:FindFirstChild("Seats") and vehicle.Seats:FindFirstChild("VehicleSeat") then
                table.insert(cars, vehicle)
            end
        end
    end
    return cars
end

local function applyToAllCars(valueType, value)
    local cars = getAllCars()
    if #cars == 0 then return end
    
    for _, vehicle in pairs(cars) do
        local vehicleSeat = vehicle.Seats.VehicleSeat
        pcall(function()
            if valueType == "MaxSpeed" then
                vehicleSeat.MaxSpeed = value
            elseif valueType == "Turbo" then
                vehicleSeat.Turbo = value
            end
        end)
    end
end

CarTab:AddTextBox({
    Name = "🚀 Max Speed Value",
    Description = "Enter max speed value",
    PlaceholderText = "200",
    Callback = function(Value)
        speedValue = tonumber(Value) or speedValue
    end
})

CarTab:AddTextBox({
    Name = "🔥 Turbo Power Value",
    Description = "Enter turbo value",
    PlaceholderText = "11.3",
    Callback = function(Value)
        turboValue = tonumber(Value) or turboValue
    end
})

CarTab:AddButton({
    Name = "⚡ Apply Speed to All",
    Callback = function()
        applyToAllCars("MaxSpeed", speedValue)
    end
})

CarTab:AddButton({
    Name = "🔥 Apply Turbo to All",
    Callback = function()
        applyToAllCars("Turbo", turboValue)
    end
})

-- Section 4: RGB (Fixed & Smooth)
CarTab:AddSection({ Name = "🌈 Car RGB" })

local isColorChanging = false
local function changeCarColor()
    while isColorChanging do
        local hue = (tick() % 5) / 5
        local color = Color3.fromHSV(hue, 1, 1)
        pcall(function()
            ReplicatedStorage.RE["1Venic1eColo1r"]:FireServer(color)
        end)
        task.wait(0.15) -- Smooth and safe delay
    end
end

CarTab:AddToggle({
    Name = "Rainbow Car RGB",
    Default = false,
    Callback = function(state)
        isColorChanging = state
        if isColorChanging then
            task.spawn(changeCarColor)
        end
    end
})

-- Initialization Fix
_G.hubCarregando = true
task.spawn(function()
    local Remotes = ReplicatedStorage:WaitForChild("Remotes", 10)
    if Remotes then
        local ResetRemote = Remotes:WaitForChild("ResetCharacterAppearance", 10)
        if ResetRemote then
            local ResetOriginal = ResetRemote.FireServer
            ResetRemote.FireServer = function(...)
                if _G.hubCarregando then return end
                return ResetOriginal(...)
            end
        end
    end
    task.wait(3)
    _G.hubCarregando = false
end)

