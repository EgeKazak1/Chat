-- 2. METADATA (DEFINITIONS) ÇEKİCİ
local function GetItemMetadata(itemName, category)
    local meta = {Rarity = "Common", Description = "Açıklama bulunamadı."}
    
    -- GearDefinitions Kontrolü
    local gearDefsModule = ReplicatedStorage:FindFirstChild("Gears") and ReplicatedStorage.Gears:FindFirstChild("Definitions") and ReplicatedStorage.Gears.Definitions:FindFirstChild("GearDefinitions")
    if gearDefsModule then
        local defs = require(gearDefsModule)
        if defs.Gears and defs.Gears[itemName] then
            meta.Rarity = defs.Gears[itemName].Rarity or meta.Rarity
            meta.Description = defs.Gears[itemName].GearDescription or meta.Description
        end
    end
    
    return meta
end

-- 3. ANA STOK ÇEKİCİ
local function FetchProStock(shopId)
    local results = {}
    local remote = ReplicatedStorage:WaitForChild("RemoteEvents"):FindFirstChild("GetShopData")
    
    if remote and remote:IsA("RemoteFunction") then
        local success, data = pcall(function() return remote:InvokeServer(shopId) end)
        if success and data then
            for name, details in pairs(data) do
                local amount = 0
                if typeof(details) == "table" then
                    amount = details.Amount or (details.StockAmount and details.StockAmount[1]) or 0
                else amount = details end
                
                local meta = GetItemMetadata(name, shopId)
                results[name] = {Amount = amount, Rarity = meta.Rarity, Desc = meta.Desc}
            end
        end
    end

    -- Yedek: Manuel Tarama (txt dosyalarındaki yapı)
    if next(results) == nil then
        local moduleName = (shopId == "SeedShop") and "SeedShopData" or "GearShopData"
        local mod = ReplicatedStorage:FindFirstChild("Shop") and ReplicatedStorage.Shop.ShopData:FindFirstChild(moduleName)
        if mod then
            local static = require(mod)
            for k, v in pairs(static.ShopData) do
                local name = v.Name or k
                local meta = GetItemMetadata(name, shopId)
                results[name] = {Amount = "Bilinmiyor", Rarity = meta.Rarity, Desc = meta.Desc}
            end
        end
    end
    return results
end

-- 4. DISCORD WEBHOOK (Tüm Özellikler Ekli)
local function SendFullBotUpdate(seeds, gears)
    local seedStr, gearStr = "", ""
    
    for name, data in pairs(seeds) do
        seedStr = seedStr .. "🌱 **" .. name .. "**\n└ 📦 Miktar: `" .. tostring(data.Amount) .. "`\n\n"
    end
    
    for name, data in pairs(gears) do
        local rarityEmoji = (data.Rarity == "Legendary" and "⭐") or (data.Rarity == "Epic" and "💜") or (data.Rarity == "Rare" and "💙") or "⚪"
        gearStr = gearStr .. "⚙️ **" .. name .. "** [" .. rarityEmoji .. " " .. data.Rarity .. "]\n└ 📦 Miktar: `" .. tostring(data.Amount) .. "`\n└ 📝 *" .. (data.Desc or "Açıklama yok") .. "*\n\n"
    end

    local payload = {
        ["embeds"] = {{
            ["title"] = "🚀 GARDEN HORIZONS - FULL FEATURE STOCK BOT",
            ["color"] = 0x00FF7F,
            ["fields"] = {
                {["name"] = "🌱 Tohumlar", ["value"] = seedStr ~= "" and seedStr or "Stok Yok", ["inline"] = false},
                {["name"] = "⚙️ Ekipmanlar (Full Özellikli)", ["value"] = gearStr ~= "" and gearStr or "Stok Yok", ["inline"] = false}
            },
            ["footer"] = {["text"] = "Bypass Mode: PRO | Dex & Definition Linked | " .. os.date("%X")}
        }}
    }

    local req = (syn and syn.request or http_request or request)
    if req then
        req({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end
end

-- 5. RAYFIELD HUB
local function InitAlchemyHub()
    local Window = Rayfield:CreateWindow({
        Name = "Alchemy PRO Stock",
        LoadingTitle = "Definitions & ShopData Syncing...",
        ConfigurationSaving = { Enabled = false }
    })

    local Tab = Window:CreateTab("📊 Full Scan", 4483362458)
    local Label = Tab:CreateLabel("Sistem: Aktif | Definitions Bağlandı")

    task.spawn(function()
        while true do
            local s = FetchProStock("SeedShop")
            local g = FetchProStock("GearShop")
            SendFullBotUpdate(s, g)
            Label:Set("Son Tarama: " .. os.date("%X"))
            Rayfield:Notify({Title = "Stok Güncellendi", Content = "Tüm metadata özellikleri Discord'a basıldı.", Duration = 3})
            task.wait(CHECK_INTERVAL)
        end
    end)
end

-- 6. VERIFY
VerifyBtn.MouseButton1Click:Connect(function()
    if tonumber(Answer.Text) == dogru_cevap then
        ScreenGui:Destroy()
        InitAlchemyHub()
    else
        VerifyBtn.Text = "YANLIŞ CEVAP"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(1)
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        VerifyBtn.Text = "SİSTEMİ TETİKLE"
    end
end)
