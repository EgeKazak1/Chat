-- 2. DEX KONTROLLÜ STOK MOTORU (Fix: Stok Var/Yok Sorunu Çözüldü)
local function FetchDeepStock(folderName)
    local results = {}
    -- Dex görüntüsündeki yol: ReplicatedStorage.Shop.ShopData
    local shopPath = game:GetService("ReplicatedStorage"):FindFirstChild("Shop")
    local dataFolder = shopPath and shopPath:FindFirstChild("ShopData") and shopPath.ShopData:FindFirstChild(folderName)

    if dataFolder then
        for _, item in pairs(dataFolder:GetChildren()) do
            -- Stok değerini bulmak için 3 farklı yöntemi dene (Bypass kontrolü)
            local amount = 0
            local valObj = item:FindFirstChild("Amount") or item:FindFirstChild("Stock") or item:FindFirstChild("Value")
            
            if valObj and (valObj:IsA("IntValue") or valObj:IsA("NumberValue")) then
                amount = valObj.Value
            elseif item:IsA("IntValue") or item:IsA("NumberValue") then
                amount = item.Value
            else
                -- Eğer değer objesi yoksa ama item oradaysa en azından 1 tane olduğunu varsay
                amount = "Mevcut" 
            end
            
            results[item.Name] = amount
        end
    end
    return results
end

-- 3. WEBHOOK RAPORLAYICI
local function PushToDiscord(seeds, gears)
    local sMsg, gMsg = "", ""
    for k, v in pairs(seeds) do sMsg = sMsg .. "🌱 **" .. k .. "**: " .. v .. "\n" end
    for k, v in pairs(gears) do gMsg = gMsg .. "⚙️ **" .. k .. "**: " .. v .. "\n" end

    local embed = {
        ["title"] = "📦 Garden Horizons - Anlık Stok Raporu",
        ["color"] = 0x00FF7F,
        ["fields"] = {
            {["name"] = "Seeds", ["value"] = sMsg ~= "" and sMsg or "Bulunamadı", ["inline"] = true},
            {["name"] = "Gears", ["value"] = gMsg ~= "" and gMsg or "Bulunamadı", ["inline"] = true}
        },
        ["footer"] = {["text"] = "Alchemy Hub | Dex Verified System"}
    }

    local req = (syn and syn.request or http_request or request)
    if req then
        req({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({["embeds"] = {embed}})
        })
    end
end

-- 4. RAYFIELD HUB & AYRI SEKMELER
local function LoadHub()
    local Window = Rayfield:CreateWindow({
        Name = "Alchemy Garden | Stock Hub",
        LoadingTitle = "Dex Verileri Senkronize Ediliyor...",
        ConfigurationSaving = { Enabled = false }
    })

    local SeedTab = Window:CreateTab("🌱 Seeds", 4483362458)
    local GearTab = Window:CreateTab("⚙️ Gears", 4483362458)

    local function Refresh()
        local seeds = FetchDeepStock("SeedShopData")
        local gears = FetchDeepStock("GearShopData")
        
        -- UI Etiketlerini Oluştur (Basit yenileme)
        SeedTab:CreateSection("Mevcut Tohumlar")
        for n, a in pairs(seeds) do SeedTab:CreateLabel(n .. ": " .. a) end
        
        GearTab:CreateSection("Mevcut Ekipmanlar")
        for n, a in pairs(gears) do GearTab:CreateLabel(n .. ": " .. a) end

        PushToDiscord(seeds, gears)
    end

    Refresh()
    Rayfield:Notify({Title = "Sistem Aktif", Content = "Stoklar Discord'a Gönderildi!", Duration = 3})
end

-- 5. DOĞRULAMA TETİĞİ
VerifyBtn.MouseButton1Click:Connect(function()
    if tonumber(AnswerBox.Text) == dogru_cevap then
        ScreenGui:Destroy()
        LoadHub()
    else
        VerifyBtn.Text = "YANLIŞ! TEKRAR DENE"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(1)
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        VerifyBtn.Text = "DOĞRULA VE GİRİŞ YAP"
    end
end)
