local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local HttpService = game:GetService("HttpService")

-- CONFIG
local WEBHOOK_URL = "https://discordapp.com/api/webhooks/1478024862718103673/KaXBdzHd5KOzltQuHWG6BWcYETFSNzsoPnC5BZPCK3o7eYwI1MEJ32KFolfTkQwpaJwl"
local REFRESH_RATE = 60 -- Saniye cinsinden stok güncelleme hızı

-- 1. ALCHEMY STYLE KEY SYSTEM (UI Tasarımı Ekran Görüntüsü 1'e Göre Hazırlandı)
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local MainFrame = Instance.new("Frame", ScreenGui)
local n1, n2 = math.random(15, 50), math.random(3, 12)
local dogru_cevap = n1 * n2

MainFrame.Size = UDim2.new(0, 350, 0, 250)
MainFrame.Position = UDim2.new(0.5, -175, 0.5, -125)
MainFrame.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
MainFrame.BorderSizePixel = 0
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

local Title = Instance.new("TextLabel", MainFrame)
Title.Text = "WELCOME TO THE,\nAlchemy Hub Bypasser"
Title.Size = UDim2.new(1, 0, 0, 60)
Title.TextColor3 = Color3.fromRGB(0, 255, 127)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 22
Title.BackgroundTransparency = 1

local GrayBox = Instance.new("Frame", MainFrame)
GrayBox.Size = UDim2.new(0, 280, 0, 50)
GrayBox.Position = UDim2.new(0.5, -140, 0.45, 0)
GrayBox.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
Instance.new("UICorner", GrayBox)

local QuestionLabel = Instance.new("TextLabel", GrayBox)
QuestionLabel.Text = "  Soru: " .. n1 .. " x " .. n2 .. " ="
QuestionLabel.TextColor3 = Color3.new(1, 1, 1)
QuestionLabel.Font = Enum.Font.GothamBold
QuestionLabel.TextSize = 18
QuestionLabel.Size = UDim2.new(0.5, 0, 1, 0)
QuestionLabel.BackgroundTransparency = 1
QuestionLabel.TextXAlignment = Enum.TextXAlignment.Left

local AnswerInput = Instance.new("TextBox", GrayBox)
AnswerInput.Size = UDim2.new(0.4, 0, 0.8, 0)
