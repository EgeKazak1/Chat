-- 2. DEX VE DOSYA KONTROLLÜ STOK ÇEKİCİ
local function FetchLiveStock(shopId)
    local results = {}
    local remoteFunction = ReplicatedStorage:WaitForChild("RemoteEvents"):FindFirstChild("GetShopData")
    
    if remoteFunction and remoteFunction:IsA("RemoteFunction") then
        local success, data = pcall(function()
            return remoteFunction:InvokeServer(shopId)
        end)
        
        if success and data then
            for name, details in pairs(data) do
                -- Miktarı tam sayı olarak alıyoruz
                local amount = 0
                if typeof(details) == "table" then
                    amount = details.Amount or (details.StockAmount and details.StockAmount[1]) or 0
                else
                    amount = details
                end
                results[name] = amount
            end
        end
    end

    -- Yedek plan: Modül dosyalarından isimleri çek
    if next(results) == nil then
        local moduleName = (shopId == "SeedShop") and "SeedShopData" or "GearShopData"
        local shopPath = ReplicatedStorage:FindFirstChild("Shop")
        local dataPath = shopPath and shopPath:FindFirstChild("ShopData")
        local module = dataPath and dataPath:FindFirstChild(moduleName)
        
        if module then
            local static = require(module)
            if static and static.ShopData then
                for key, val in pairs(static.ShopData) do
                    results[val.Name or key] = "Kontrol Ediliyor..."
                end
            end
        end
    end
    
    return results
end

-- 3. WEBHOOK GÖNDERİMİ (Detaylı Liste Formatı)
local function PostToDiscord(seeds, gears)
    local seedContent = ""
    local gearContent = ""

    -- Seeds Listesi (Teker teker)
    local seedCount = 0
    for n, q in pairs(seeds) do 
        seedCount = seedCount + 1
        seedContent = seedContent .. "🌱 **" .. n .. "**: " .. tostring(q) .. " adet\n" 
    end
    if seedContent == "" then seedContent = "❌ Tohum stoğu bulunamadı." end

    -- Gears Listesi (Teker teker)
    local gearCount = 0
    for n, q in pairs(gears) do 
        gearCount = gearCount + 1
        gearContent = gearContent .. "⚙️ **" .. n .. "**: " .. tostring(q) .. " adet\n" 
    end
    if gearContent == "" then gearContent = "❌ Ekipman stoğu bulunamadı." end

    local embed = {
        ["title"] = "📦 Garden Horizons - Detaylı Stok Raporu",
        ["description"] = "Aşağıdaki ürünler mağazada teker teker tespit edilmiştir:",
        ["color"] = 0x00FF7F,
        ["fields"] = {
            {["name"] = "Tohum Listesi ("..seedCount..")", ["value"] = seedContent, ["inline"] = false},
            {["name"] = "Ekipman Listesi ("..gearCount..")", ["value"] = gearContent, ["inline"] = false}
        },
        ["footer"] = {["text"] = "Bypass Mode: Active | Alchemy Hub | " .. os.date("%X")}
    }

    local req = (syn and syn.request or http_request or request)
    if req then
        req({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({["embeds"] = {embed}})
        })
    end
end

-- 4. RAYFIELD HUB BAŞLATMA
local function LoadHub()
    local Window = Rayfield:CreateWindow({
        Name = "Alchemy Stock Hub",
        LoadingTitle = "Decompiled Data Syncing...",
        ConfigurationSaving = { Enabled = false }
    })

    local MainTab = Window:CreateTab("📊 Canlı Liste", 4483362458)
    local LogLabel = MainTab:CreateLabel("Bot Başlatıldı: Stoklar taranıyor...")
    
    task.spawn(function()
        while true do
            local seeds = FetchLiveStock("SeedShop")
            local gears = FetchLiveStock("GearShop")
            
            PostToDiscord(seeds, gears)
            
            LogLabel:Set("Son Güncelleme: " .. os.date("%X"))
            Rayfield:Notify({
                Title = "Stok Güncellendi",
                Content = "Tüm ürünler teker teker listelenip Discord'a gönderildi.",
                Duration = 3
            })
            
            task.wait(CHECK_INTERVAL)
        end
    end)
end

-- 5. DOĞRULAMA MANTIĞI
VerifyBtn.MouseButton1Click:Connect(function()
    if tonumber(Answer.Text) == dogru_cevap then
        ScreenGui:Destroy()
        LoadHub()
    else
        VerifyBtn.Text = "HATALI CEVAP"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(1)
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        VerifyBtn.Text = "BOTU TETİKLE"
    end
end)
