   Name = "Evi Herkese Aç (Unlock House)",
   Callback = function()
      RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("HouseLock", false)
   end,
})

WorldTab:CreateButton({
   Name = "Tüm Işıkları Kapat",
   Callback = function()
      RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("LightSwitch", false)
   end,
})

WorldTab:CreateButton({
   Name = "Yangın Çıkar",
   Callback = function()
      RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("FirePlace", true)
   end,
})

-- VISUALS & AVATAR
