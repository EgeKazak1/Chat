--[[
    GARDEN HORIZONS: ULTIMATE STOCK BYPASSER (RAYFIELD EDITION)
    - Discord Webhook Devre Dışı (Tüm veriler menüde)
    - Detaylı Eşya İsimlendirme & Bilgi Kartları
    - Rarity & Description Entegrasyonu
    - Canlı RemoteFunction Tetikleme
]]--

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- AYARLAR
local CHECK_INTERVAL = 45 -- Saniye cinsinden yenileme hızı

-- 1. DOĞRULAMA EKRANI (Alchemy Tasarımı)
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local MainFrame = Instance.new("Frame", ScreenGui)
local n1, n2 = math.random(10, 50), math.random(4, 9)
local dogru_cevap = n1 * n2

MainFrame.Size = UDim2.new(0, 340, 0, 240)
MainFrame.Position = UDim2.new(0.5, -170, 0.5, -120)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

local Header = Instance.new("TextLabel", MainFrame)
Header.Text = "ALCHEMY HUB\nLive Stock Interface"
Header.Size = UDim2.new(1, 0, 0, 60)
Header.TextColor3 = Color3.fromRGB(0, 255, 127)
Header.Font = Enum.Font.GothamBold
Header.TextSize = 20
Header.BackgroundTransparency = 1

local InputBox = Instance.new("Frame", MainFrame)
InputBox.Size = UDim2.new(0.85, 0, 0, 55)
InputBox.Position = UDim2.new(0.075, 0, 0.45, 0)
InputBox.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
Instance.new("UICorner", InputBox)

local Question = Instance.new("TextLabel", InputBox)
Question.Text = "  " .. n1 .. " x " .. n2 .. " ="
Question.TextColor3 = Color3.new(1, 1, 1)
Question.Font = Enum.Font.GothamBold
Question.Size = UDim2.new(0.4, 0, 1, 0)
Question.BackgroundTransparency = 1
Question.TextXAlignment = Enum.TextXAlignment.Left

local Answer = Instance.new("TextBox", InputBox)
Answer.Size = UDim2.new(0.5, 0, 0.8, 0)
Answer.Position = UDim2.new(0.45, 0, 0.1, 0)
Answer.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
Answer.TextColor3 = Color3.fromRGB(0, 255, 127)
Answer.PlaceholderText = "?"
Answer.Text = ""
Instance.new("UICorner", Answer)

local VerifyBtn = Instance.new("TextButton", MainFrame)
VerifyBtn.Size = UDim2.new(0.85, 0, 0, 45)
VerifyBtn.Position = UDim2.new(0.075, 0, 0.75, 0)
VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
VerifyBtn.Text = "MENÜYÜ AÇ"
VerifyBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", VerifyBtn)

-- 2. VERİ YÖNETİCİSİ (Definitions & ShopData)
local function GetMetaData(itemName)
    local meta = {Rarity = "Common", Desc = "Açıklama yok."}
    -- GearDefinitions.txt yapısına göre kontrol
    local gearDefsModule = ReplicatedStorage:FindFirstChild("Gears") and ReplicatedStorage.Gears:FindFirstChild("Definitions") and ReplicatedStorage.Gears.Definitions:FindFirstChild("GearDefinitions")
    if gearDefsModule then
        local defs = require(gearDefsModule)
        if defs.Gears and defs.Gears[itemName] then
            meta.Rarity = defs.Gears[itemName].Rarity or "Common"
            meta.Desc = defs.Gears[itemName].GearDescription or "Açıklama yok."
        end
    end
    return meta
end

local function FetchLiveStock(shopType)
    local list = {}
    local remote = ReplicatedStorage:WaitForChild("RemoteEvents"):FindFirstChild("GetShopData")
    
    if remote and remote:IsA("RemoteFunction") then
        local success, data = pcall(function() return remote:InvokeServer(shopType) end)
        if success and data then
            for name, details in pairs(data) do
                local amt = (typeof(details) == "table" and (details.Amount or (details.StockAmount and details.StockAmount[1]))) or details or 0
                local meta = GetMetaData(name)
                list[name] = {Amount = amt, Rarity = meta.Rarity, Desc = meta.Desc}
            end
        end
    end

    -- Yedek plan: Remote çalışmazsa Modül dosyasından isimleri çek
    if next(list) == nil then
        local modName = (shopType == "SeedShop" and "SeedShopData") or "GearShopData"
        local mod = ReplicatedStorage:FindFirstChild("Shop") and ReplicatedStorage.Shop.ShopData:FindFirstChild(modName)
        if mod then
            local static = require(mod)
            for k, v in pairs(static.ShopData) do
                local name = v.Name or k
                local meta = GetMetaData(name)
                list[name] = {Amount = "Yükleniyor...", Rarity = meta.Rarity, Desc = meta.Desc}
            end
        end
    end
    return list
end

-- 3. RAYFIELD ARAYÜZÜ
local function StartRayfield()
    local Window = Rayfield:CreateWindow({
        Name = "Alchemy Hub | Stok Takibi",
        LoadingTitle = "Dosyalar Senkronize Ediliyor...",
        ConfigurationSaving = { Enabled = false }
    })

    local SeedTab = Window:CreateTab("🌱 Tohumlar", 4483362458)
    local GearTab = Window:CreateTab("⚙️ Ekipmanlar", 4483362458)

    local seedLabels = {}
    local gearLabels = {}

    -- Ekranda sürekli güncellenen döngü
    task.spawn(function()
        while true do
            -- Seeds Güncelleme
            local seeds = FetchLiveStock("SeedShop")
            for name, data in pairs(seeds) do
                local labelText = "🌱 " .. name .. " | Stok: " .. tostring(data.Amount)
                if not seedLabels[name] then
                    seedLabels[name] = SeedTab:CreateParagraph({Title = name, Content = "Miktar: " .. tostring(data.Amount)})
                else
                    seedLabels[name]:Set({Title = name, Content = "Miktar: " .. tostring(data.Amount)})
                end
            end

            -- Gears Güncelleme
            local gears = FetchLiveStock("GearShop")
            for name, data in pairs(gears) do
                local rEmoji = (data.Rarity == "Legendary" and "⭐") or (data.Rarity == "Epic" and "💜") or (data.Rarity == "Rare" and "💙") or "⚪"
                local fullTitle = rEmoji .. " " .. name .. " [" .. data.Rarity .. "]"
                local fullDesc = "Stok: " .. tostring(data.Amount) .. "\nBilgi: " .. data.Desc

                if not gearLabels[name] then
                    gearLabels[name] = GearTab:CreateParagraph({Title = fullTitle, Content = fullDesc})
                else
                    gearLabels[name]:Set({Title = fullTitle, Content = fullDesc})
                end
            end

            Rayfield:Notify({Title = "Sistem", Content = "Stoklar Güncellendi!", Duration = 2})
            task.wait(CHECK_INTERVAL)
        end
    end)
end

-- 4. VERIFY BUTONU
VerifyBtn.MouseButton1Click:Connect(function()
    if tonumber(Answer.Text) == dogru_cevap then
        ScreenGui:Destroy()
        StartRayfield()
    else
        VerifyBtn.Text = "HATALI!"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(1)
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        VerifyBtn.Text = "MENÜYÜ AÇ"
    end
end)
