                local fires = {
                    {"PlayEmote", "67", plr},
                    {"Emote", "67"},
                    {"Emotes", "67", true},
                    {"PlayEmote", 67, plr},
                    {"PlayEmote", "67"}
                }
                for _, args in ipairs(fires) do
                    pcall(function()
                        trigger:FireServer(unpack(args))
                    end)
                end
            end
        end)

