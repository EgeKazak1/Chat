    Title = "🧺 Candy Basket",
    Callback = function()
        local names = {"CandyBasket", "CandyBasketTool", "Candy_Basket"}
        for _, n in ipairs(names) do
            pcall(function() TriggerEvent:FireServer("AcceptedToolToServer", n, LocalPlayer) end)
        end
    end
})

