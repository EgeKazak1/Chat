-- ==========================================
-- 🚗 GAMEPASS BYPASS (ID: 1459820822)
-- ==========================================
-- Oyunun senin bu gamepass'e sahip olduğunu sanmasını sağlayan hook işlemi
pcall(function()
    local MPS = game:GetService("MarketplaceService")
    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        -- Eğer oyun gamepass kontrolü yapıyorsa ve ID Araç Özelleştirme ID'si ise TRUE döndür
        if not checkcaller() and self == MPS and method == "UserOwnsGamePassAsync" then
            if args[1] == 1459820822 or args[2] == 1459820822 then
                return true
            end
        end
        return oldNamecall(self, ...)
    end)
end)

