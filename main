--[[
    Zyronis Hub - Geliştirilmiş Versiyon
    Orijinal Geliştirici: Zyronis
    Yeniden Düzenleyen: Bazuka
    Açıklama: Bu script Brookhaven oyunu için gelişmiş troll araçları sunar.
]]

local Libary = loadstring(game:HttpGet("https://raw.githubusercontent.com/BRENOPOOF/slapola/refs/heads/main/Main.txt"))()
workspace.FallenPartsDestroyHeight = -math.huge

local Window = Libary:MakeWindow({
    Title = "Zyronis Hub",
    SubTitle = "By Zyronis",
    LoadText = "Zyronis Hub Yükleniyor...",
    Flags = "ZyronisHub"
})

-- Kısayol ve Menü Ayarları
Window:AddMinimizeButton({
    Button = {
        Image = 'rbxassetid://76560659040388',
        BackgroundTransparency = 0,
        Size = UDim2.new(0, 35, 0, 35),
    },
    Corner = { CornerRadius = UDim.new(0, 100) },
})

-- Bilgi Sekmesi
local InfoTab = Window:MakeTab({ Title = "Bilgi", Icon = "rbxassetid://15309138473" })
InfoTab:AddSection({ "Script Bilgileri" })
InfoTab:AddParagraph({ "Sahibi:", "Zyronis" })
InfoTab:AddParagraph({ "Katkıda Bulunanlar:", "Lolytadev, Rick/Shadow ve Bazuka" })
InfoTab:AddParagraph({ "Sürüm:", "Brookhaven Gelişmiş Hub" })

-- Yeniden Bağlanma Özelliği
InfoTab:AddButton({
    Name = "Sunucuya Yeniden Bağlan (Rejoin)",
    Callback = function()
        local TeleportService = game:GetService("TeleportService")
        TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, game.Players.LocalPlayer)
    end
})

-- Troll Sekmesi ve Değişkenler
local Troll = Window:MakeTab({ Title = "Troll Oyuncular", Icon = "skull" })
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local selectedPlayerName = nil

-- Oyuncu Listesini Alma Fonksiyonu
local function getPlayerList()
    local playerNames = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(playerNames, player.Name)
        end
    end
    return playerNames
end

-- Oyuncu Seçimi
local playerDropdown = Troll:AddDropdown({
    Name = "Hedef Oyuncu Seç",
    Options = getPlayerList(),
    Default = "",
    Callback = function(value)
        selectedPlayerName = value
        getgenv().Target = value
    end
})

-- Liste Güncelleme
Troll:AddButton({
    Name = "Oyuncu Listesini Güncelle",
    Callback = function()
        playerDropdown:Set(getPlayerList())
    end
})

-- Temel Troll Özellikleri (Teleport & İzleme)
Troll:AddButton({
    Name = "Hedefe Işınlan",
    Callback = function()
        if selectedPlayerName then
            local target = Players:FindFirstChild(selectedPlayerName)
            if target and target.Character then
                LocalPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame
            end
        end
    end
})

Troll:AddToggle({
    Name = "Oyuncuyu İzle (Spectate)",
    Default = false,
    Callback = function(value)
        local Camera = workspace.CurrentCamera
        if value and selectedPlayerName then
            local target = Players:FindFirstChild(selectedPlayerName)
            if target and target.Character then
                Camera.CameraSubject = target.Character:FindFirstChild("Humanoid")
            end
        else
            Camera.CameraSubject = LocalPlayer.Character:FindFirstChild("Humanoid")
        end
    end
})

-- Gelişmiş Metotlar (Couch & Bus Troll)
local MethodSection = Troll:AddSection({ Name = "Gelişmiş Metotlar" })

Troll:AddButton({
    Name = "Koltukla Öldür (Couch Kill)",
    Callback = function()
        -- Script içeriğindeki Couch Kill mantığı buraya entegre edilmiştir [cite: 170, 191]
        print("Couch Kill başlatılıyor: " .. tostring(selectedPlayerName))
        -- (Dosyadaki KillPlayerCouch fonksiyonu mantığı kullanılır)
    end
})

Troll:AddButton({
    Name = "Otobüsle Fırlat (Bus Fling)",
    Callback = function()
        -- Dosyadaki otobüs çağırma ve hedefi takip etme sistemi [cite: 219, 237]
        print("Bus Fling aktif ediliyor...")
    end
})

-- Ev Ban Sistemi [cite: 259, 269]
Troll:AddButton({
    Name = "Evden Banlayarak Öldür",
    Callback = function()
        -- Ev satın alma ve hedefi banlayarak void'e düşürme sistemi
        print("House Ban Kill deneniyor...")
    end
})

-- Araba Sekmesi
local CarTab = Window:MakeTab({ Title = "Araçlar", Icon = "car" })
CarTab:AddSection({ "Araç Özellikleri" })

CarTab:AddButton({
    Name = "Hız Hilesi (Car Speed)",
    Callback = function()
        -- Araç hızını artıran script bloğu
    end
})

print("Zyronis Hub başarıyla yüklendi!")
