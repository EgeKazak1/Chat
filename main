Tab:AddSection({ "🎯 Parça Seç & Yükle" })

_G.parteSelecionada = "Gövde"

Tab:AddDropdown({
    Name = "📦 Parça Seç",
    Description = "Hangi parçayı kuşanacağını seç",
    Default = "Gövde",
    Options = {"Gövde", "Sağ Kol", "Sol Kol", "Sağ Bacak", "Sol Bacak", "Kafa"},
    Callback = function(Value)
        _G.parteSelecionada = Value
        print("📦 Seçilen parça: " .. Value)
    end
})

Tab:AddButton({
    Name = "🎯 Seçili Parçayı Giydir",
    Description = "Sadece seçilen parçayı uygular",
    Callback = function()
        local args = {
            [1] = {0, 0, 0, 0, 0, 0}
        }
        
        if _G.parteSelecionada == "Gövde" and _G.selectedParts.Torso then
            args[1][1] = _G.selectedParts.Torso
        elseif _G.parteSelecionada == "Sağ Kol" and _G.selectedParts.BracoDireito then
            args[1][2] = _G.selectedParts.BracoDireito
        elseif _G.parteSelecionada == "Sol Kol" and _G.selectedParts.BracoEsquerdo then
            args[1][3] = _G.selectedParts.BracoEsquerdo
        elseif _G.parteSelecionada == "Sağ Bacak" and _G.selectedParts.PernaDireita then
            args[1][4] = _G.selectedParts.PernaDireita
        elseif _G.parteSelecionada == "Sol Bacak" and _G.selectedParts.PernaEsquerda then
            args[1][5] = _G.selectedParts.PernaEsquerda
        elseif _G.parteSelecionada == "Kafa" and _G.selectedParts.Cabeca then
            args[1][6] = _G.selectedParts.Cabeca
        else
            print("❌ Hata: Seçili parça boş!")
            return
        end
        
        pcall(function()
            game:GetService("ReplicatedStorage").Remotes.ChangeCharacterBody:InvokeServer(unpack(args))
        end)
        print("✅ Parça başarıyla giydirildi!")
    end
})

Tab:AddButton({
    Name = "🚀 Tüm Parçaları Yükle",
    Description = "Tüm girilen parçaları aynı anda uygular",
    Callback = function()
        local temAlgumaParteSelecionada = _G.selectedParts.Torso or _G.selectedParts.BracoDireito or 
                                         _G.selectedParts.BracoEsquerdo or _G.selectedParts.PernaDireita or 
                                         _G.selectedParts.PernaEsquerda or _G.selectedParts.Cabeca
        
        if not temAlgumaParteSelecionada then
            print("❌ Hata: Hiç parça girilmedi!")
            return
        end
        
        local args = {
            [1] = {
                _G.selectedParts.Torso or 0,
                _G.selectedParts.BracoDireito or 0,
                _G.selectedParts.BracoEsquerdo or 0,
                _G.selectedParts.PernaDireita or 0,
                _G.selectedParts.PernaEsquerda or 0,
                _G.selectedParts.Cabeca or 0
            }
        }
        
        pcall(function()
            game:GetService("ReplicatedStorage").Remotes.ChangeCharacterBody:InvokeServer(unpack(args))
        end)
        print("🚀 Tüm parçalar başarıyla yüklendi!")
    end
})

