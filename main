-- 2. REPLICATEDSTORAGE / SHOPDATA KONTROLCÜSÜ
-- .txt dosyalarındaki hiyerarşiyi (Shop.ShopData) birebir takip eder
local function FetchShopStock(shopId)
    local results = {}
    local remoteFunction = ReplicatedStorage:WaitForChild("RemoteEvents"):FindFirstChild("GetShopData")
    
    -- Önce sunucudan canlı veriyi çekmeyi dene
    if remoteFunction and remoteFunction:IsA("RemoteFunction") then
        local success, data = pcall(function()
            return remoteFunction:InvokeServer(shopId)
        end)
        
        if success and data then
            for name, details in pairs(data) do
                local amount = 0
                if typeof(details) == "table" then
                    amount = details.Amount or (details.StockAmount and details.StockAmount[1]) or 0
                else
                    amount = details
                end
                results[name] = amount
            end
        end
    end

    -- Eğer canlı veri boşsa, ReplicatedStorage içindeki Modülleri (txt ile aynı yapıda olanlar) oku
    if next(results) == nil then
        local moduleName = (shopId == "SeedShop") and "SeedShopData" or "GearShopData"
        local shopDataFolder = ReplicatedStorage:FindFirstChild("Shop") and ReplicatedStorage.Shop:FindFirstChild("ShopData")
        local module = shopDataFolder and shopDataFolder:FindFirstChild(moduleName)
        
        if module then
            local staticData = require(module)
            if staticData and staticData.ShopData then
                for itemName, itemInfo in pairs(staticData.ShopData) do
                    -- Modüldeki ismi veya anahtar kelimeyi al (Carrot Seed, Watering Can vb.)
                    results[itemInfo.Name or itemName] = "Bekleniyor..."
                end
            end
        end
    end
    
    return results
end

-- 3. WEBHOOK GÖNDERİMİ (Teker Teker Yazı Formatı)
local function PostDetailedStock(seeds, gears)
    local seedList = ""
    local gearList = ""
    local sCount, gCount = 0, 0

    -- Tohumları tek tek işle
    for name, qty in pairs(seeds) do 
        sCount = sCount + 1
        seedList = seedList .. "🌱 **" .. name .. "**: " .. tostring(qty) .. " adet mevcut\n" 
    end
    if seedList == "" then seedList = "⚠️ Tohum verisi alınamadı." end

    -- Ekipmanları tek tek işle
    for name, qty in pairs(gears) do 
        gCount = gCount + 1
        gearList = gearList .. "⚙️ **" .. name .. "**: " .. tostring(qty) .. " adet mevcut\n" 
    end
    if gearList == "" then gearList = "⚠️ Ekipman verisi alınamadı." end

    local embed = {
        ["title"] = "📢 GARDEN HORIZONS STOK RAPORU",
        ["description"] = "Aşağıdaki ürünler oyun dosyaları ve sunucu verileriyle senkronize edildi.",
        ["color"] = 0x00FF7F,
        ["fields"] = {
            {["name"] = "Tohum Stokları ("..sCount..")", ["value"] = seedList, ["inline"] = false},
            {["name"] = "Ekipman Stokları ("..gCount..")", ["value"] = gearList, ["inline"] = false}
        },
        ["footer"] = {["text"] = "Alchemy Hub | Dex & Module Kontrollü | " .. os.date("%X")}
    }

    local request = (syn and syn.request or http_request or request)
    if request then
        request({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({["embeds"] = {embed}})
        })
    end
end

-- 4. ANA PANEL (RAYFIELD)
local function StartSystem()
    local Window = Rayfield:CreateWindow({
        Name = "Alchemy Stock Hub",
        LoadingTitle = "Shop Folder Bağlantısı Kuruluyor...",
        ConfigurationSaving = { Enabled = false }
    })

    local MainTab = Window:CreateTab("📊 Canlı Takip", 4483362458)
    local StatusLabel = MainTab:CreateLabel("Bot durumu: Aktif (Taramada)")
    
    task.spawn(function()
        while true do
            -- ShopFolder içindeki Seed ve Gear verilerini tetikle
            local seeds = FetchShopStock("SeedShop")
            local gears = FetchShopStock("GearShop")
            
            -- Discord'a teker teker yazdır
            PostDetailedStock(seeds, gears)
            
            StatusLabel:Set("Son Tarama: " .. os.date("%X"))
            Rayfield:Notify({
                Title = "Stoklar Güncellendi",
                Content = "Shop folder verileri teker teker Discord'a yazdırıldı.",
                Duration = 3
            })
            
            task.wait(CHECK_INTERVAL)
        end
    end)
end

-- 5. DOĞRULAMA TETİĞİ
VerifyBtn.MouseButton1Click:Connect(function()
    if tonumber(Answer.Text) == dogru_cevap then
        ScreenGui:Destroy()
        StartSystem()
    else
        VerifyBtn.Text = "HATALI CEVAP"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        task.wait(1)
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        VerifyBtn.Text = "BOTU TETİKLE"
    end
end)
