   Callback = function()
      RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("LightSwitch", true)
      task.wait(0.2)
      RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("LightSwitch", false)
   end,
})

WorldTab:CreateButton({
   Name = "Yangın Çıkar",
   Callback = function()
      RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("FirePlace", true)
   end,
})

WorldTab:CreateSection("Genel Sabotaj")

WorldTab:CreateToggle({
   Name = "Otomatik Bomba Patlat (Loop Bomb)",
   CurrentValue = false,
   Callback = function(Value)
      _G.LoopBomb = Value
      task.spawn(function()
         while _G.LoopBomb do
            local bombTool = workspace:WaitForChild("WorkspaceCom"):WaitForChild("001_CriminalWeapons"):WaitForChild("GiveTools"):WaitForChild("Bomb")
            if bombTool then
                fireclickdetector(bombTool.ClickDetector)
                task.wait(0.1)
                VIM:SendMouseButtonEvent(500, 500, 0, true, game, 0)
                task.wait(0.1)
                VIM:SendMouseButtonEvent(500, 500, 0, false, game, 0)
                RS:WaitForChild("RE"):WaitForChild("1Blo1wBomb1sServe1r"):FireServer("Bomb" .. Player.Name)
            end
            task.wait(1)
         end
      end)
   end,
})

-- ARAÇLAR SEKMESİ
VehicleTab:CreateSection("Araç Troll")

VehicleTab:CreateButton({
   Name = "Askeri Bot Fling (Military Boat)",
   Callback = function()
      RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer("SpawnVehicle", "MilitaryBoat", RootPart.CFrame)
      task.wait(0.5)
      local boat = workspace.Vehicles:FindFirstChild(Player.Name .. "MilitaryBoat")
      if boat then
          local bV = Instance.new("BodyAngularVelocity", boat.PrimaryPart)
          bV.AngularVelocity = Vector3.new(0, 99999, 0)
          bV.MaxTorque = Vector3.new(0, 99999, 0)
          Rayfield:Notify({Title = "Fling Aktif", Content = "Bota dokunan uçar!", Duration = 3})
      end
   end,
})

VehicleTab:CreateButton({
   Name = "Tüm Araçları Sil (Anti-Lag)",
   Callback = function()
      RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer("RemoveVehicles")
   end,
})

