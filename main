-- Xeno Team UI Library (Rayfield tabanlı özelleştirilmiş yapı)
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Xeno Hub | Brookhaven 🏆",
   LoadingTitle = "Xeno Team Premier",
   LoadingSubtitle = "by Xeno Team",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "XenoConfigs",
      FileName = "XenoHub"
   },
   KeySystem = false -- Gerekirse true yapılıp anahtar eklenebilir
})

-- Değişkenler
local Player = game.Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local RootPart = Character:WaitForChild("HumanoidRootPart")
local RS = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

-- Yardımcı Fonksiyonlar
local function GetPlayer(name)
    for _, v in pairs(game.Players:GetPlayers()) do
        if v.Name:lower():find(name:lower()) or v.DisplayName:lower():find(name:lower()) then
            return v
        end
    end
end

-- TABS
local MainTab = Window:CreateTab("Oyuncu Troll", 4483362458) -- Ana Özellikler
local VisualsTab = Window:CreateTab("Görsel & Avatar", 4483362458)
local MiscTab = Window:CreateTab("Diğer", 4483362458)

-- MAIN FEATURES
MainTab:CreateSection("Hedef Belirle")

local targetPlayer = ""
MainTab:CreateInput({
   Name = "Oyuncu Adı",
   PlaceholderText = "İsim yazın...",
   RemoveTextAfterFocusLost = false,
   Callback = function(Text)
      targetPlayer = Text
   end,
})

MainTab:CreateSection("İmha Yöntemleri")

MainTab:CreateButton({
   Name = "Kanepe İle Öldür (Couch Kill)",
   Callback = function()
      local target = GetPlayer(targetPlayer)
      if target then
         -- Geliştirilmiş Xeno Çekme Mantığı
         local args = { [1] = "Couch", [2] = target.Character.HumanoidRootPart.CFrame }
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer(unpack(args))
         -- Void Işınlama
         task.wait(0.2)
         local voidArgs = { [1] = "Couch", [2] = CFrame.new(0, -500, 0) }
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer(unpack(voidArgs))
      end
   end,
})

MainTab:CreateButton({
   Name = "Otobüs İle Uçur (Bus Kill)",
   Callback = function()
      local target = GetPlayer(targetPlayer)
      if target then
         -- Otobüs çağırma ve hedefi içine alma
         RS:WaitForChild("RE"):WaitForChild("s1chool1bus"):FireServer(target.Name)
         task.wait(0.5)
         -- Aracı harita dışına itme
         local args = { [1] = "SetVehicleCFrame", [2] = CFrame.new(9999, 9999, 9999) }
         RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer(unpack(args))
      end
   end,
})

MainTab:CreateSection("Genel Troll")

MainTab:CreateButton({
   Name = "Ultra Fling (Hızlı Dönüş)",
   Callback = function()
      local Bam = Instance.new("BodyAngularVelocity")
      Bam.Parent = RootPart
      Bam.Name = "XenoFling"
      Bam.AngularVelocity = Vector3.new(0, 99999, 0)
      Bam.MaxTorque = Vector3.new(0, 99999, 0)
      Bam.P = 1250
      
      task.wait(5) -- 5 saniye sonra durur
      if RootPart:FindFirstChild("XenoFling") then
          RootPart.XenoFling:Destroy()
      end
   end,
})

-- VISUALS & AVATAR
VisualsTab:CreateSection("Avatar Dönüşümleri")

VisualsTab:CreateButton({
   Name = "Mini Karakter Ol",
   Callback = function()
      local args = { [1] = "skinnyscale", [2] = 0.3 }
      RS:WaitForChild("RE"):WaitForChild("A1vatar1Re1mote"):FireServer(unpack(args))
   end,
})

VisualsTab:CreateButton({
   Name = "Stickman (Çöp Adam)",
   Callback = function()
      -- Xeno Team Özel Stickman Ayarı
      local args = { [1] = "setpackage", [2] = "Stickman" }
      RS:WaitForChild("RE"):WaitForChild("A1vatar1Re1mote"):FireServer(unpack(args))
   end,
})

-- MISC TAB
MiscTab:CreateSection("Sunucu Ayarları")

MiscTab:CreateButton({
   Name = "Sunucu Değiştir (Server Hop)",
   Callback = function()
      local PlaceID = game.PlaceId
      local AllIDs = {}
      local foundAnything = ""
      local actualHour = os.date("!*t").hour
      local function TPReturner()
         local Site;
         if foundAnything == "" then
            Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100'))
         else
            Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100&cursor=' .. foundAnything))
         end
         local ID = ""
         if Site.nextPageCursor and Site.nextPageCursor ~= "null" and Site.nextPageCursor ~= nil then
            foundAnything = Site.nextPageCursor
         end
         local num = 0;
         for i,v in pairs(Site.data) do
            ID = tostring(v.id)
            if tonumber(v.maxPlayers) > tonumber(v.playing) then
               for _,Existing in pairs(AllIDs) do
                  if ID == tostring(Existing) then
                  end
               end
               num = num + 1
               table.insert(AllIDs, ID)
               wait()
               game:GetService("TeleportService"):TeleportToPlaceInstance(PlaceID, ID, Player)
            end
         end
      end
      TPReturner()
   end,
})

MiscTab:CreateButton({
   Name = "FPS Sabitleyici (Anti-Lag)",
   Callback = function()
      for _, v in pairs(workspace:GetDescendants()) do
         if v:IsA("BasePart") and not v.Parent:FindFirstChild("Humanoid") then
            v.Material = Enum.Material.SmoothPlastic
         end
      end
      settings().Rendering.QualityLevel = 1
   end,
})

-- Bildirim
Rayfield:Notify({
   Title = "Xeno Hub Yüklendi!",
   Content = "Xeno Team iyi oyunlar diler.",
   Duration = 5,
   Image = 4483362458,
})
