-- 🧍‍♂️ VIP DARK CHARACTER MENU (ENHANCED & TRANSLATED) 🖤✨
local Tab = Window:MakeTab({"🧍‍♂️ Avatar 🖤", "rbxassetid://10734952036"})

-- Services & Constants
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local StarterGui = game:GetService("StarterGui")
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local LocalPlayer = Players.LocalPlayer

-- Global State Management
getgenv().Target = nil
_G.selectedParts = { Torso = 0, RightArm = 0, LeftArm = 0, RightLeg = 0, LeftLeg = 0, Head = 0 }
_G.selectedCategory = "Torso"

-- Helper Functions
local function Notify(title, text)
    StarterGui:SetCore("SendNotification", {
        Title = title,
        Text = text,
        Duration = 3
    })
end

local function GetPlayerNames()
    local names = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(names, player.Name)
        end
    end
    return names
end

-- Section: Skin Copy (VIP)
Tab:AddSection({ Name = "🎭 VIP Outfit Stealer" })

local PlayerDropdown = Tab:AddDropdown({
    Name = "👤 Select Target Player",
    Options = GetPlayerNames(),
    Default = "",
    Callback = function(value)
        getgenv().Target = value
        print("🎯 Target set to: " .. tostring(value))
    end
})

local function RefreshDropdown()
    local newNames = GetPlayerNames()
    PlayerDropdown:Refresh(newNames, true)
    print("🔄 Player list refreshed.")
end

Players.PlayerAdded:Connect(RefreshDropdown)
Players.PlayerRemoving:Connect(RefreshDropdown)

Tab:AddButton({
    Name = "🔄 Refresh Player List",
    Callback = RefreshDropdown
})

Tab:AddButton({
    Name = "🎭 Copy Character Appearance",
    Callback = function()
        if not getgenv().Target then 
            return Notify("Error", "Please select a player first!") 
        end

        local TargetPlayer = Players:FindFirstChild(getgenv().Target)
        if not (TargetPlayer and TargetPlayer.Character) then return end

        local LHumanoid = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        local THumanoid = TargetPlayer.Character:FindFirstChildOfClass("Humanoid")

        if LHumanoid and THumanoid then
            -- 1. Clear Current Appearance (Optional but cleaner)
            local LDesc = LHumanoid:GetAppliedDescription()
            
            -- Remove Accessories & Clothing via Remotes
            local toRemove = {LDesc.Shirt, LDesc.Pants, LDesc.Face}
            for _, assetId in ipairs(toRemove) do
                if tonumber(assetId) and assetId > 0 then
                    Remotes.Wear:InvokeServer(tonumber(assetId))
                    task.wait(0.1)
                end
            end

            -- 2. Fetch Target Appearance
            local PDesc = THumanoid:GetAppliedDescription()

            -- Apply Body Parts
            local bodyArgs = {{
                PDesc.Torso, PDesc.RightArm, PDesc.LeftArm, 
                PDesc.RightLeg, PDesc.LeftLeg, PDesc.Head
            }}
            Remotes.ChangeCharacterBody:InvokeServer(unpack(bodyArgs))
            task.wait(0.3)

            -- Apply Clothing & Face
            local assets = {PDesc.Shirt, PDesc.Pants, PDesc.Face, PDesc.IdleAnimation}
            for _, id in ipairs(assets) do
                if tonumber(id) and id > 0 then
                    Remotes.Wear:InvokeServer(tonumber(id))
                    task.wait(0.2)
                end
            end

            -- Apply Accessories
            for _, acc in ipairs(PDesc:GetAccessories(true)) do
                if acc.AssetId then
                    Remotes.Wear:InvokeServer(tonumber(acc.AssetId))
                    task.wait(0.2)
                end
            end

            -- Apply Bio & Name (RP Details)
            local Bag = TargetPlayer:FindFirstChild("PlayersBag")
            if Bag then
                if Bag:FindFirstChild("RPName") then Remotes.RPNameText:FireServer("RolePlayName", Bag.RPName.Value) end
                if Bag:FindFirstChild("RPBio") then Remotes.RPNameText:FireServer("RolePlayBio", Bag.RPBio.Value) end
                if Bag:FindFirstChild("RPNameColor") then Remotes.RPNameColor:FireServer("PickingRPNameColor", Bag.RPNameColor.Value) end
            end

            Notify("Success", "Character copied successfully!")
        end
    end
})

