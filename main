Tab:AddButton({
    Name = "🔥 Fire Rengini Giydir",
    Callback = function()
        local fireColors = {
            ["White"] = { id="18637074370", code="030FireWhite" },
            ["Orange"] = { id="18637025451", code="031FireOrange" },
            ["Green"] = { id="18637078598", code="032FireGreen" },
            ["Blue"] = { id="18637076370", code="033FireBlue" },
            ["Purple"] = { id="18637070174", code="034FirePurple" },
            ["Black"] = { id="18637072603", code="035FireBlack" },
        }

        local selectedColor = _G.selectedColor or "White"

        if fireColors[selectedColor] then
            local data = fireColors[selectedColor]
            game:GetService("ReplicatedStorage").Remotes.ApplyEmmiter:InvokeServer(data.id, data.code)
            print("🔥 Fire giydirildi: " .. selectedColor)
        else
            warn("❌ Hata: Fire rengi bulunamadı!")
        end
    end
})

