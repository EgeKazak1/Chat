-- Troll Sekmesi ve Değişkenler
local Troll = Window:MakeTab({ Title = "Troll Oyuncular", Icon = "skull" })
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local selectedPlayerName = nil

-- Oyuncu Listesini Alma Fonksiyonu
local function getPlayerList()
    local playerNames = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(playerNames, player.Name)
        end
    end
    return playerNames
end

-- Oyuncu Seçimi
local playerDropdown = Troll:AddDropdown({
    Name = "Hedef Oyuncu Seç",
    Options = getPlayerList(),
    Default = "",
    Callback = function(value)
        selectedPlayerName = value
        getgenv().Target = value
    end
})

-- Liste Güncelleme
Troll:AddButton({
    Name = "Oyuncu Listesini Güncelle",
    Callback = function()
        playerDropdown:Set(getPlayerList())
    end
})

-- Temel Troll Özellikleri (Teleport & İzleme)
Troll:AddButton({
    Name = "Hedefe Işınlan",
    Callback = function()
        if selectedPlayerName then
            local target = Players:FindFirstChild(selectedPlayerName)
            if target and target.Character then
                LocalPlayer.Character.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame
            end
        end
    end
})

Troll:AddToggle({
    Name = "Oyuncuyu İzle (Spectate)",
    Default = false,
    Callback = function(value)
        local Camera = workspace.CurrentCamera
        if value and selectedPlayerName then
            local target = Players:FindFirstChild(selectedPlayerName)
            if target and target.Character then
                Camera.CameraSubject = target.Character:FindFirstChild("Humanoid")
            end
        else
            Camera.CameraSubject = LocalPlayer.Character:FindFirstChild("Humanoid")
        end
    end
})

-- Gelişmiş Metotlar (Couch & Bus Troll)
local MethodSection = Troll:AddSection({ Name = "Gelişmiş Metotlar" })

Troll:AddButton({
    Name = "Koltukla Öldür (Couch Kill)",
    Callback = function()
        -- Script içeriğindeki Couch Kill mantığı buraya entegre edilmiştir [cite: 170, 191]
        print("Couch Kill başlatılıyor: " .. tostring(selectedPlayerName))
        -- (Dosyadaki KillPlayerCouch fonksiyonu mantığı kullanılır)
    end
})

Troll:AddButton({
    Name = "Otobüsle Fırlat (Bus Fling)",
    Callback = function()
        -- Dosyadaki otobüs çağırma ve hedefi takip etme sistemi [cite: 219, 237]
        print("Bus Fling aktif ediliyor...")
    end
})

-- Ev Ban Sistemi [cite: 259, 269]
Troll:AddButton({
    Name = "Evden Banlayarak Öldür",
    Callback = function()
        -- Ev satın alma ve hedefi banlayarak void'e düşürme sistemi
        print("House Ban Kill deneniyor...")
    end
})

-- Araba Sekmesi
local CarTab = Window:MakeTab({ Title = "Araçlar", Icon = "car" })
-- ==========================================
-- VEHICLE CUSTOMIZATION & TURBO (ENGLISH)
-- ==========================================

local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Variables for Decal and UUID
local CurrentDecal = ""
local CurrentVehicleUUID = nil

-- Variables for Spam Loops
local spammingHeadLights = false
local spammingHazardLights = false
local spammingHorn = false

-- Function: Apply Tire Decal
local function ApplyDecal(decalId)
    if not CurrentVehicleUUID then return end
    local formattedDecal = "http://www.roblox.com/asset/?id=" .. decalId
    
    pcall(function()
        local Remote = ReplicatedStorage.Remotes.SuspensionHeightChanged
        firesignal(Remote.OnClientEvent, CurrentVehicleUUID)
        
        ReplicatedStorage.Remotes.ApplyStateToVehicle:InvokeServer(
            CurrentVehicleUUID,
            {
                ["Appearance"] = {
                    ["WheelDecal"] = formattedDecal,
                    ["SuspensionHeight"] = 1.1,
                },
                ["Sahip"] = LocalPlayer,
            }
        )
    end)
end

-- Track Spawned Vehicle UUID
ReplicatedStorage.Remotes.PlayerSpawnedVehicle.OnClientEvent:Connect(function(data)
    if data and data.uuid then
        CurrentVehicleUUID = data.uuid
    end
end)

-- 1. TIRE DECAL SECTION
CarTab:AddSection({ Name = "🛞 Tire Customization" })

CarTab:AddTextbox({
    Name = "Tire Decal ID",
    Default = "",
    PlaceholderText = "Enter Decal ID...",
    Callback = function(text)
        local cleanId = text:match("%d+")
        if cleanId then CurrentDecal = cleanId end
    end
})

CarTab:AddButton({
    Name = "Apply Decal to Wheels",
    Callback = function()
        if CurrentDecal ~= "" then ApplyDecal(CurrentDecal) end
    end
})

-- 2. LIGHTS & HORN SPAM SECTION
CarTab:AddSection({ Name = "🚨 Vehicle Spams" })

CarTab:AddToggle({
    Name = "Spam Headlights",
    Default = false,
    Callback = function(value)
        spammingHeadLights = value
        task.spawn(function()
            while spammingHeadLights do
                ReplicatedStorage.Remotes.ToggleHeadLights:InvokeServer()
                task.wait(0.1)
            end
        end)
    end
})

CarTab:AddToggle({
    Name = "Spam Hazard Lights",
    Default = false,
    Callback = function(value)
        spammingHazardLights = value
        task.spawn(function()
            while spammingHazardLights do
                ReplicatedStorage.Remotes.ToggleHazardLights:InvokeServer()
                task.wait(0.1)
            end
        end)
    end
})

CarTab:AddToggle({
    Name = "Spam Horn",
    Default = false,
    Callback = function(value)
        spammingHorn = value
        if spammingHorn then
            task.spawn(function()
                while spammingHorn do
                    ReplicatedStorage.Remotes.PlayHorn:InvokeServer()
                    task.wait(0.1)
                end
            end)
        else
            ReplicatedStorage.Remotes.StopHorn:InvokeServer()
        end
    end
})

-- 3. SPEED & TURBO SECTION (ALL CARS)
CarTab:AddSection({ Name = "🏎️ Speed & Turbo Control" })

local speedValue = 200
local turboValue = 11.3

local function applyToAllCars(valueType, value)
    if not workspace:FindFirstChild("Vehicles") then return end
    for _, vehicle in pairs(workspace.Vehicles:GetChildren()) do
        local seat = vehicle:FindFirstChild("Seats") and vehicle.Seats:FindFirstChild("VehicleSeat")
        if seat then
            pcall(function()
                if valueType == "MaxSpeed" then seat.MaxSpeed = value
                elseif valueType == "Turbo" then seat.Turbo = value end
            end)
        end
    end
end

CarTab:AddTextbox({
    Name = "Set Max Speed",
    PlaceholderText = "200",
    Callback = function(Value)
        speedValue = tonumber(Value) or 200
    end
})

CarTab:AddButton({
    Name = "Apply Speed to All Cars",
    Callback = function() applyToAllCars("MaxSpeed", speedValue) end
})

-- 4. OPTIMIZED RGB SECTION
CarTab:AddSection({ Name = "🌈 Car RGB (Free Colors)" })

local isColorChanging = false
CarTab:AddToggle({
    Name = "Rainbow Car RGB",
    Default = false,
    Callback = function(state)
        isColorChanging = state
        if isColorChanging then
            task.spawn(function()
                while isColorChanging do
                    -- Using HSV to RGB for smooth transition (Free in Brookhaven)
                    local hue = tick() % 5 / 5
                    local color = Color3.fromHSV(hue, 1, 1)
                    
                    pcall(function()
                        -- Uses the main color remote
                        ReplicatedStorage.RE["1Venic1eColo1r"]:FireServer(color)
                    end)
                    task.wait(0.1) -- Optimized delay to prevent lag
                end
            end)
        end
    end
})

-- Fix for Loading State
_G.hubCarregando = false
end
print("Zyronis Hub başarıyla yüklendi!")
-- Eşyalar (Items) Sekmesi Oluşturma
local ItemsTab = Window:MakeTab({ Title = "Eşyalar", Icon = "rbxassetid://15309138473" })

-- Değişkenleri bir kez tanımlayalım (Optimizasyon)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local RE = ReplicatedStorage:FindFirstChild("RE")
local TriggerEvent = RE and RE:FindFirstChild("1Playe1rTrigge1rEven1t")

-- Yardımcı Fonksiyon: Bildirim Gönder
local function sendNotify(title, text)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = 3
        })
    end)
end

-- 1. Money Gun (Gelişmiş Kontrollü)
ItemsTab:AddButton({
    Title = "💸 Money Gun",
    Callback = function()
        local itemName = "MoneyGun"
        local candidates = {"GetItem", "Getİtem", "Get_Item", "GetTool"}
        
        for _, name in ipairs(candidates) do
            local r = RE:FindFirstChild(name)
            if r then
                if r:IsA("RemoteFunction") then r:InvokeServer(itemName)
                else r:FireServer(itemName) end
                sendNotify("Money Gun", name .. " üzerinden istendi.")
                return
            end
        end
        
        if TriggerEvent then
            TriggerEvent:FireServer("AcceptedToolToServer", itemName, LocalPlayer)
            sendNotify("Money Gun", "Trigger ile verildi.")
        end
    end
})

-- 2. Glider
ItemsTab:AddButton({
    Title = "🪂 Glider",
    Callback = function()
        if TriggerEvent then TriggerEvent:FireServer("AcceptedToolToServer", "Glider", LocalPlayer) end
    end
})

