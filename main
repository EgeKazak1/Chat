    Default = false,
    Flag = "custom_body_toggle",
    Callback = function(Value)
        if not _G.togglesInicializadas["Small"] then
            _G.togglesInicializadas["Small"] = true
            return
        end
        
        local customBody = {
            104157277410075,
            86280536086607,
            81974054542977,
            74524984742501,
            122626731952977,
            134082579
        }
        
        if Value then
            game:GetService("ReplicatedStorage").Remotes.ChangeCharacterBody:InvokeServer(customBody)
            print("📏 Small Body aktif!")
        else
            game:GetService("ReplicatedStorage").Remotes.ResetCharacterAppearance:FireServer()
            print("🔄 Small Body kapatıldı.")
        end
    end
})

