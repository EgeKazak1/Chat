Instance.new("UICorner", VerifyBtn)

-- 2. VERİ YÖNETİMİ (Dex/Explorer Bağlantılı)
local function GetStockData(folderName)
    local results = {}
    -- Dex Görüntüleri: ReplicatedStorage > Shop > ShopData > [Folder]
    local path = game:GetService("ReplicatedStorage"):FindFirstChild("Shop") 
        and game:GetService("ReplicatedStorage").Shop:FindFirstChild("ShopData")
    
    if path and path:FindFirstChild(folderName) then
        for _, item in pairs(path[folderName]:GetChildren()) do
            -- Bazı oyunlarda değer Name içinde, bazılarında Amount objesi içindedir
            local amount = item:FindFirstChild("Amount") and item.Amount.Value or "Check Dex"
            results[item.Name] = amount
        end
    end
    return results
end

local function SendWebhook(seedData, gearData)
    local seedMsg = ""
    local gearMsg = ""

    for k, v in pairs(seedData) do seedMsg = seedMsg .. "🌱 " .. k .. ": " .. v .. "\n" end
    for k, v in pairs(gearData) do gearMsg = gearMsg .. "⚙️ " .. k .. ": " .. v .. "\n" end

    local payload = {
        ["embeds"] = {{
            ["title"] = "🟢 Garden Horizons - Canlı Stok Raporu",
            ["color"] = 65280,
            ["fields"] = {
                {["name"] = "Seeds (Tohumlar)", ["value"] = seedMsg ~= "" and seedMsg or "Stok Yok", ["inline"] = true},
                {["name"] = "Gears (Ekipmanlar)", ["value"] = gearMsg ~= "" and gearMsg or "Stok Yok", ["inline"] = true}
            },
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%SZ")
        }}
    }
    
    local req = (syn and syn.request or http_request or request)
    if req then
        req({
            Url = WEBHOOK_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(payload)
        })
    end
end

-- 3. ANA PANEL VE OTOMASYON
local function StartHub()
    local Window = Rayfield:CreateWindow({
        Name = "Alchemy Hub | Stock Monitor",
        LoadingTitle = "Veriler Yükleniyor...",
        ConfigurationSaving = { Enabled = false }
    })

    local SeedTab = Window:CreateTab("🌱 Seeds", 4483362458)
    local GearTab = Window:CreateTab("⚙️ Gears", 4483362458)

    task.spawn(function()
        while true do
            -- Verileri Çek
            local sData = GetStockData("SeedShopData")
            local gData = GetStockData("GearShopData")

            -- UI Temizle ve Güncelle (Basitlik için her döngüde yeniler)
            -- Not: Rayfield'da mevcut etiketleri güncellemek için değişken atamak daha iyidir.
            
            -- Discord'a Gönder
            SendWebhook(sData, gData)
            
            task.wait(REFRESH_RATE)
        end
    end)
    
    SeedTab:CreateLabel("Otomatik Webhook Aktif (60s)")
    GearTab:CreateLabel("Stoklar Ayrı Sekmelerde Takip Ediliyor")
end

-- 4. DOĞRULAMA BUTONU FONKSİYONU
VerifyBtn.MouseButton1Click:Connect(function()
    if tonumber(AnswerInput.Text) == dogru_cevap then
        ScreenGui:Destroy()
        StartHub()
        Rayfield:Notify({Title = "Başarılı", Content = "Script Yüklendi!", Duration = 3})
    else
        VerifyBtn.Text = "YANLIŞ CEVAP!"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        task.wait(1)
        VerifyBtn.Text = "REDEEM & START"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
    end
end)
