local RGBTab = Window:MakeTab({ "RGB 🌈", "rbxassetid://97889814027474" })

RGBTab:AddSection({ "🎨 ÁREA RGB" })

local rgbSpeed = 3

RGBTab:AddTextBox({
    Name = "⚡ RGB Hızı",
    Description = "Escolha uma Velocidade Para O RGB",
    Default = tostring(rgbSpeed),
    ClearText = false,
    Callback = function(v)
        local n = tonumber(v)
        if n and n > 0 then
            rgbSpeed = n
        end
    end
})

-- Genel RGB loop fonksiyonu (bozulmadan)
local function startRGBLoop(flagFunc, actionFunc, delayTime, mode)
    task.spawn(function()
        while flagFunc() do
            local hue = (tick() * rgbSpeed % 5) / 5
            local color
            if mode == "normal" then
                color = Color3.fromHSV(hue, 1, 1)
            elseif mode == "dark" then
                color = Color3.fromHSV(hue, 0.8, 0.4)
            elseif mode == "vip" then
                color = Color3.fromHSV(hue, 0.9, 0.3)
            end
            pcall(function()
                actionFunc(color)
            end)
            task.wait(delayTime)
        end
    end)
end

