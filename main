local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local HttpService = game:GetService("HttpService")

-- 1. MATEMATİK KEY UI (Alchemy Style)
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local MainFrame = Instance.new("Frame", ScreenGui)
local n1, n2 = math.random(10, 50), math.random(2, 8)
local dogru_cevap = n1 * n2

-- UI Özellikleri (Alchemy Tasarımı)
MainFrame.Size = UDim2.new(0, 330, 0, 220)
MainFrame.Position = UDim2.new(0.5, -165, 0.5, -110)
MainFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

local GrayBox = Instance.new("Frame", MainFrame)
GrayBox.Size = UDim2.new(0.9, 0, 0, 50)
GrayBox.Position = UDim2.new(0.05, 0, 0.45, 0)
GrayBox.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
Instance.new("UICorner", GrayBox)

local QuestionLabel = Instance.new("TextLabel", GrayBox)
QuestionLabel.Text = "  " .. n1 .. " x " .. n2 .. " ="
QuestionLabel.TextColor3 = Color3.new(0, 0, 0) -- SİYAH YAZI
QuestionLabel.Font = Enum.Font.GothamBold
QuestionLabel.Size = UDim2.new(0.4, 0, 1, 0)
QuestionLabel.BackgroundTransparency = 1

local AnswerInput = Instance.new("TextBox", GrayBox)
AnswerInput.Size = UDim2.new(0.5, 0, 1, 0)
AnswerInput.Position = UDim2.new(0.45, 0, 0, 0)
AnswerInput.BackgroundTransparency = 1
AnswerInput.TextColor3 = Color3.new(0, 0, 0) -- SİYAH YAZI
AnswerInput.Font = Enum.Font.GothamBold
AnswerInput.Text = ""

local VerifyBtn = Instance.new("TextButton", MainFrame)
VerifyBtn.Size = UDim2.new(0.9, 0, 0, 45)
VerifyBtn.Position = UDim2.new(0.05, 0, 0.75, 0)
VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
VerifyBtn.Text = "REDEEM & OPEN HUB"
VerifyBtn.Font = Enum.Font.GothamBold
Instance.new("UICorner", VerifyBtn)

-- 2. RAYFIELD HUB FONKSİYONU
local function OpenRayfield()
    local Window = Rayfield:CreateWindow({
       Name = "Alchemy Garden | Stock Hub",
       LoadingTitle = "Bypassing Replica Data...",
       LoadingSubtitle = "by Hile Ustası",
       ConfigurationSaving = { Enabled = false }
    })

    local StockTab = Window:CreateTab("📦 Live Stock", 4483362458)
    
    -- Örnek Stok Verileri (Burayı oyun içi Replica yollarıyla bağlayabilirsin)
    local SeedLabel = StockTab:CreateLabel("🌱 Seeds: Loading...")
    local GearLabel = StockTab:CreateLabel("⚙️ Gears: Loading...")
    
    -- Canlı Güncelleme Döngüsü
    task.spawn(function()
        while task.wait(5) do
            -- Replica Kontrollü Tetikleme Simülasyonu
            local seeds = math.random(0, 100) 
            local gears = math.random(0, 20)
            SeedLabel:Set("🌱 Seeds Stock: " .. seeds)
            GearLabel:Set("⚙️ Gears Stock: " .. gears)
        end
    end)

    StockTab:CreateButton({
       Name = "Refresh Stock",
       Callback = function()
           Rayfield:Notify({Title = "Stock", Content = "Veriler Yenilendi!", Duration = 2})
       end,
    })
end

-- 3. DOĞRULAMA TETİKLEYİCİ
VerifyBtn.MouseButton1Click:Connect(function()
    if tonumber(AnswerInput.Text) == dogru_cevap then
        ScreenGui:Destroy()
        OpenRayfield()
    else
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        VerifyBtn.Text = "WRONG ANSWER"
        task.wait(1)
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 255, 127)
        VerifyBtn.Text = "REDEEM & OPEN HUB"
    end
end)
