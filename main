-- Global kontrol değişkeni (Sistemi durdurmak için)
local isSkipped = false

-- Noktalar
for i = 1, 35 do
    local ponto = Instance.new("Frame")
    ponto.Size = UDim2.new(0, math.random(4,7), 0, math.random(4,7))
    ponto.Position = UDim2.new(math.random(), 0, math.random(), 0)
    ponto.AnchorPoint = Vector2.new(0.5,0.5)
    ponto.BackgroundColor3 = ROXO_PRINCIPAL
    ponto.BackgroundTransparency = 0.25
    ponto.Parent = Frame
    Instance.new("UICorner", ponto).CornerRadius = UDim.new(1,0)

    local stroke = Instance.new("UIStroke")
    stroke.Color = ROXO_PRINCIPAL
    stroke.Thickness = 1
    stroke.Transparency = 0.4
    stroke.Parent = ponto

    task.spawn(function()
        while not isSkipped and ScreenGui.Parent do
            TweenService:Create(ponto,TweenInfo.new(math.random(2,3),Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{Size=UDim2.new(0,9,0,9),BackgroundTransparency=0.05}):Play()
            task.wait(1.5)
            if isSkipped then break end
            TweenService:Create(ponto,TweenInfo.new(math.random(2,3),Enum.EasingStyle.Sine,Enum.EasingDirection.InOut),{Size=UDim2.new(0,5,0,5),BackgroundTransparency=0.35}):Play()
            task.wait(1.5)
        end
    end)
end

