local Players = game:GetService("Players")
local Player = Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local VIM = game:GetService("VirtualInputManager")

-- Xeno Tema Renkleri
local XENO_PURPLE = Color3.fromRGB(145, 90, 230)
local XENO_DARK = Color3.fromRGB(55, 35, 110)

-- Arayüz Kütüphanesi
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Xeno Hub | Brookhaven ULTIMATE 🏆",
   LoadingTitle = "Xeno Team Premier Pro",
   LoadingSubtitle = "by Xeno Team",
   ConfigurationSaving = { Enabled = true, FolderName = "XenoConfigs", FileName = "XenoUltimate" },
   KeySystem = false 
})

-- Durum Değişkenleri
_G.TargetPlayer = ""
_G.LoopBomb = false
_G.AutoRob = false

-- Fonksiyonlar
local function GetPlayer(name)
    name = name:lower()
    for _, v in pairs(Players:GetPlayers()) do
        if v.Name:lower():find(name) or v.DisplayName:lower():find(name) then
            return v
        end
    end
    return nil
end

-- TABS
local TrollTab = Window:CreateTab("Troll Ana Menü", 4483362458)
local AvatarTab = Window:CreateTab("Avatar & Item", 4483362458)
local WorldTab = Window:CreateTab("Dünya & Soygun", 4483362458)
local VehicleTab = Window:CreateTab("Araç Modifiye", 4483362458)
local SettingsTab = Window:CreateTab("Sistem", 4483362458)

-- TROLL SEKMESİ
TrollTab:CreateSection("Hedef Oyuncu Seçimi")
TrollTab:CreateInput({
   Name = "Oyuncu Adı",
   PlaceholderText = "İsim yazın...",
   Callback = function(Text) _G.TargetPlayer = Text end,
})

TrollTab:CreateSection("Gelişmiş Öldürme Metodları")
TrollTab:CreateButton({
   Name = "Couch Kill (Kanepe - Void)",
   Callback = function()
      local target = GetPlayer(_G.TargetPlayer)
      if target and target.Character then
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer("Couch", target.Character.HumanoidRootPart.CFrame)
         task.wait(0.2)
         RS:WaitForChild("RE"):WaitForChild("vibe"):FireServer("Couch", CFrame.new(0, -1000, 0))
      end
   end,
})

TrollTab:CreateButton({
   Name = "Bus Kill (Okul Otobüsü)",
   Callback = function()
      local target = GetPlayer(_G.TargetPlayer)
      if target then
         RS:WaitForChild("RE"):WaitForChild("s1chool1bus"):FireServer(target.Name)
         task.wait(0.5)
         RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer("SetVehicleCFrame", CFrame.new(0, 9999, 0))
      end
   end,
})

TrollTab:CreateButton({
   Name = "Fling (Askeri Bot İle)",
   Callback = function()
      RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer("SpawnVehicle", "MilitaryBoat", Player.Character.HumanoidRootPart.CFrame)
      task.wait(0.3)
      local boat = workspace.Vehicles:FindFirstChild(Player.Name .. "MilitaryBoat")
      if boat then
          local bV = Instance.new("BodyAngularVelocity", boat.PrimaryPart)
          bV.AngularVelocity = Vector3.new(0, 99999, 0)
          bV.MaxTorque = Vector3.new(0, 99999, 0)
      end
   end,
})

-- AVATAR & ITEM SEKMESİ
AvatarTab:CreateSection("Özel Itemler & Silahlar")
AvatarTab:CreateButton({
   Name = "Tüm Eşyaları Al (Tüm Toollar)",
   Callback = function()
      local tools = {"Bomb", "Hammer", "KeyCard", "Ladders", "SleepingBag"}
      for _, tool in pairs(tools) do
         local clickPart = workspace:WaitForChild("WorkspaceCom"):WaitForChild("001_CriminalWeapons"):WaitForChild("GiveTools"):FindFirstChild(tool)
         if clickPart then fireclickdetector(clickPart.ClickDetector) end
      end
   end,
})

AvatarTab:CreateSection("Avatar Modifiye")
AvatarTab:CreateButton({
   Name = "Mini Avatar (0.3x)",
   Callback = function() RS:WaitForChild("RE"):WaitForChild("A1vatar1Re1mote"):FireServer("skinnyscale", 0.3) end,
})
AvatarTab:CreateButton({
   Name = "Görünmez İsim",
   Callback = function() RS:WaitForChild("RE"):WaitForChild("A1vatar1Re1mote"):FireServer("setname", " ") end,
})
AvatarTab:CreateButton({
   Name = "Stickman Ol",
   Callback = function() RS:WaitForChild("RE"):WaitForChild("A1vatar1Re1mote"):FireServer("setpackage", "Stickman") end,
})

-- DÜNYA & SOYGUN SEKMESİ
WorldTab:CreateSection("Otomatik İşlemler")
WorldTab:CreateToggle({
   Name = "Otomatik Kasa Patlat (Auto Rob)",
   CurrentValue = false,
   Callback = function(Value)
      _G.AutoRob = Value
      task.spawn(function()
         while _G.AutoRob do
            -- Banka Kasasına Işınlan ve Patlat
            Player.Character.HumanoidRootPart.CFrame = CFrame.new(602, 38, -10) -- Banka Kasa Konumu (Örnek)
            task.wait(1)
            RS:WaitForChild("RE"):WaitForChild("1Blo1wBomb1sServe1r"):FireServer("Bomb" .. Player.Name)
            task.wait(2)
         end
      end)
   end,
})

WorldTab:CreateButton({
   Name = "Tüm Işıkları Boz",
   Callback = function()
      while task.wait(0.1) do
         RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("LightSwitch", true)
         task.wait(0.1)
         RS:WaitForChild("RE"):WaitForChild("h1ouse1"):FireServer("LightSwitch", false)
      end
   end,
})

-- ARAÇ SEKMESİ
VehicleTab:CreateSection("Hız & Görünüm")
VehicleTab:CreateSlider({
   Name = "Araç Hızı (Speed)",
   Range = {0, 250},
   Increment = 10,
   Suffix = "kmh",
   CurrentValue = 50,
   Callback = function(Value)
      RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer("SetVehicleSpeed", Value)
   end,
})

VehicleTab:CreateButton({
   Name = "Rainbow Araba (Gökkuşağı)",
   Callback = function()
      task.spawn(function()
         while true do
            for i = 0, 1, 0.01 do
               RS:WaitForChild("RE"):WaitForChild("v1ehicle1"):FireServer("SetVehicleColor", Color3.fromHSV(i, 1, 1))
               task.wait(0.1)
            end
         end
      end)
   end,
})

-- SİSTEM SEKMESİ
SettingsTab:CreateButton({
   Name = "Sunucu Değiştir (Server Hop)",
   Callback = function()
      local PlaceID = game.PlaceId
      local Site = game.HttpService:JSONDecode(game:HttpGet('https://games.roblox.com/v1/games/' .. PlaceID .. '/servers/Public?sortOrder=Asc&limit=100'))
      for _, v in pairs(Site.data) do
         if v.playing < v.maxPlayers then
            game:GetService("TeleportService"):TeleportToPlaceInstance(PlaceID, v.id, Player)
         end
      end
   end,
})

-- Başlangıç Bildirimi
Rayfield:Notify({
   Title = "Xeno Hub Ultimate Yüklendi!",
   Content = "Xeno Team iyi eğlenceler diler.",
   Duration = 5,
   Image = 4483362458,
})
