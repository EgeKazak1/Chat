Instance.new("UICorner", AnswerInput)

local VerifyBtn = Instance.new("TextButton", MainFrame)
VerifyBtn.Size = UDim2.new(0, 280, 0, 45)
VerifyBtn.Position = UDim2.new(0.5, -140, 0.75, 0)
VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100)
VerifyBtn.Text = "REDEEM & START"
